#!/usr/bin/env bash
set -euo pipefail

pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
local_staging="${HOME}/.local/share/thunderbird-backup"
LAST_RESTORE_FILE="${HOME}/.config/tbblock/last-restore"
ownership_marker=".owned-by-thunderbird-backup"
default_repo_subdir="localfolders-restic"
default_profile_repo_subdir="profile-restic"
timers=(
    tb-localfolders-backup.timer
    tb-localfolders-prune.timer
)

usage() {
    cat <<EOF
Usage: $(basename "$0")

Run read-only health checks for Thunderbird backup, restore, Local Folders restic,
pCloud state, timers, and destructive-sync safety markers.
EOF
}

for arg in "$@"; do
    case "${arg}" in
        -h|--help) usage; exit 0 ;;
        *)
            echo "Error: Unknown option: ${arg}" >&2
            usage >&2
            exit 1
            ;;
    esac
done

ok_count=0
warn_count=0
fail_count=0

ok() {
    printf 'OK    %s\n' "$1"
    (( ok_count++ )) || true
}

warn() {
    printf 'WARN  %s\n' "$1"
    (( warn_count++ )) || true
}

fail() {
    printf 'FAIL  %s\n' "$1"
    (( fail_count++ )) || true
}

check_file() {
    local path="$1"
    local label="$2"
    if [[ -f "${path}" ]]; then
        ok "${label}: ${path}"
    else
        fail "${label} missing: ${path}"
    fi
}

get_manifest_value() {
    local manifest="$1"
    local key="$2"
    [[ -f "${manifest}" ]] || return 0
    awk -F= -v key="${key}" '$1 == key { print $2; exit }' "${manifest}"
}

run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 10s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

restic_env_prefix=()

echo "Thunderbird Backup Doctor"
echo "Date:    $(date '+%Y-%m-%d %H:%M:%S')"
echo "Machine: $(hostname -s)"
echo

if [[ -d "${pcloud_mount}" ]]; then
    pcloud_backup_root="${pcloud_mount}/${backup_root_rel}"
    ok "pCloud mounted at ${pcloud_mount}"
elif [[ -d "${pcloud_drive}" ]]; then
    pcloud_backup_root="${pcloud_drive}/${backup_root_rel}"
    ok "pCloud drive found at ${pcloud_drive}"
else
    pcloud_backup_root=""
    fail "pCloud backup root not found (${pcloud_mount} or ${pcloud_drive})"
fi

if [[ -n "${pcloud_backup_root}" ]]; then
    if [[ -d "${pcloud_backup_root}" ]]; then
        ok "Backup root exists: ${pcloud_backup_root}"
    else
        fail "Backup root missing: ${pcloud_backup_root}"
    fi

    if [[ -w "${pcloud_backup_root}" ]]; then
        ok "Backup root is writable"
    else
        fail "Backup root is not writable"
    fi
fi

echo
echo "Profile Backup"

if [[ -n "${pcloud_backup_root}" ]]; then
    profile_backup="${pcloud_backup_root}/thunderbird"
    profile_repo="${pcloud_backup_root}/${default_profile_repo_subdir}"
    manifest="${profile_backup}/.backup_manifest"

    if [[ -d "${profile_backup}" ]]; then
        ok "Current compatibility mirror exists"
    else
        fail "Current compatibility mirror missing: ${profile_backup}"
    fi

    check_file "${manifest}" "Current mirror manifest"
    check_file "${profile_backup}/prefs.js" "Current mirror prefs.js"

    manifest_date=$(get_manifest_value "${manifest}" date)
    manifest_profile=$(get_manifest_value "${manifest}" profile)
    if [[ -n "${manifest_date}" ]]; then
        ok "Current mirror date: ${manifest_date}"
    else
        warn "Current mirror date unavailable"
    fi
    if [[ -n "${manifest_profile}" ]]; then
        ok "Profile backup profile: ${manifest_profile}"
    else
        warn "Profile backup profile unavailable"
    fi

    for owned_dir in thunderbird profile-root metadata; do
        dir="${pcloud_backup_root}/${owned_dir}"
        marker="${dir}/${ownership_marker}"
        if [[ -d "${dir}" ]]; then
            if [[ -f "${marker}" ]]; then
                ok "Safety marker present: ${owned_dir}/${ownership_marker}"
            else
                warn "Safety marker missing until next backup marks existing directory: ${owned_dir}/${ownership_marker}"
            fi
        else
            warn "Backup-owned directory missing: ${owned_dir}"
        fi
    done

    if [[ -f "${profile_repo}/config" ]]; then
        ok "Durable profile restic repository exists"
    else
        warn "Durable profile restic repository not initialized: ${profile_repo}"
    fi
fi

echo
echo "Local Folders Restic"

if [[ -n "${pcloud_backup_root}" ]]; then
    lf_repo="${pcloud_backup_root}/${default_repo_subdir}"
    pw_file="${pcloud_backup_root}/.restic-password"

    if [[ -f "${pw_file}" ]]; then
        ok "Restic password file exists"
        if [[ "$(stat -c '%a' "${pw_file}" 2>/dev/null || true)" == "600" ]]; then
            ok "Restic password file mode is 600"
        else
            warn "Restic password file mode is not 600"
        fi
        restic_env_prefix=(env "RESTIC_REPOSITORY=${lf_repo}" "RESTIC_PASSWORD_FILE=${pw_file}")
    elif [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        ok "Restic password provided by environment"
        restic_env_prefix=(env "RESTIC_REPOSITORY=${lf_repo}")
    else
        fail "Restic password unavailable (${pw_file} missing and no RESTIC_PASSWORD/RESTIC_PASSWORD_FILE)"
        restic_env_prefix=()
    fi

    if [[ -f "${lf_repo}/config" ]]; then
        ok "Local Folders restic repository exists"
    else
        fail "Local Folders restic repository missing: ${lf_repo}"
    fi

    if command -v restic >/dev/null 2>&1; then
        ok "restic command found"
        if [[ -f "${lf_repo}/config" && ${#restic_env_prefix[@]} -gt 0 ]]; then
            if run_quick_check "${restic_env_prefix[@]}" restic snapshots --tag local-folders; then
                ok "Restic local-folder snapshots are readable"
            else
                fail "Restic local-folder snapshots are not readable"
            fi
            if run_quick_check "${restic_env_prefix[@]}" restic check --read-data-subset=0%; then
                ok "Restic repository metadata check passed"
            else
                warn "Restic repository metadata check failed or timed out"
            fi
        fi
    else
        fail "restic command not found"
    fi
fi

echo
echo "Restore State"

if [[ -f "${LAST_RESTORE_FILE}" ]]; then
    last_restore=$(cat "${LAST_RESTORE_FILE}")
    ok "Last restore recorded: ${last_restore}"
else
    warn "No last-restore record found"
fi

echo
echo "Timers"

if command -v systemctl >/dev/null 2>&1; then
    for timer in "${timers[@]}"; do
        enabled_output=$(systemctl --user is-enabled "${timer}" 2>&1) && enabled_status=0 || enabled_status=$?
        case "${enabled_status}" in
            0) ok "${timer} enabled" ;;
            1)
                if [[ "${enabled_output}" == Failed* ]]; then
                    warn "${timer} enablement unavailable (${enabled_output})"
                else
                    warn "${timer} not enabled (${enabled_output})"
                fi
                ;;
            *) warn "${timer} enablement unavailable (${enabled_output})" ;;
        esac

        active_output=$(systemctl --user is-active "${timer}" 2>&1) && active_status=0 || active_status=$?
        case "${active_status}" in
            0) ok "${timer} active" ;;
            3)
                if [[ "${active_output}" == Failed* ]]; then
                    warn "${timer} activity unavailable (${active_output})"
                else
                    warn "${timer} not active (${active_output})"
                fi
                ;;
            *) warn "${timer} activity unavailable (${active_output})" ;;
        esac
    done
else
    warn "systemctl not found"
fi

echo
echo "Install Links"

if [[ -d "${HOME}/bin" ]]; then
    ok "~/bin exists"
else
    warn "~/bin missing"
fi

for tool in thunderbird-backup thunderbird-restore thunderbird-report thunderbird-localfolders-backup thunderbird-doctor; do
    if [[ -L "${HOME}/bin/${tool}" ]]; then
        ok "${tool} linked in ~/bin"
    else
        warn "${tool} is not linked in ~/bin"
    fi
done

if [[ -d "${local_staging}" ]]; then
    ok "Local profile staging exists: ${local_staging}"
else
    warn "Local profile staging missing: ${local_staging}"
fi

echo
echo "Summary: ${ok_count} OK, ${warn_count} WARN, ${fail_count} FAIL"

if (( fail_count > 0 )); then
    exit 1
fi
