#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
default_profile_repo_subdir="profile-restic"
dry_run=false
self_test=false
self_test_root=""
ownership_marker=".owned-by-thunderbird-backup"
subcmd="backup"
force_non_review=false
NO_REVIEW_FILE="${HOME}/.config/tbblock/no-review"
non_review_localfolders_only=false

usage() {
    cat <<EOF
Usage: $(basename "$0") [--dry-run] [--self-test] [--force-non-review] [SUBCOMMAND]

Subcommands (default: backup):
  backup             Update the current profile mirror and snapshot if configured
  init-profile-repo  Initialize the profile restic repository
  profile-snapshots  List profile restic snapshots

Options:
  --dry-run    Show what would be backed up without making changes
  --self-test  Run a safe self-test using temporary data
  --force-non-review
               Allow publishing the shared profile backup from a non-review machine
  -h, --help   Show this help
EOF
}

have_restic_password() {
    [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" || -f "${restic_password_file:-}" ]]
}

run_profile_restic() {
    local repo="$1"
    shift

    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic "$@"
    else
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic "$@"
    fi
}

run_rsync_capture() {
    local output status

    set +e
    output=$("$@" 2>&1)
    status=$?
    set -e

    case "${status}" in
        0)
            ;;
        24)
            echo "Warning: rsync reported vanished source files (exit code 24)." >&2
            echo "This usually means the Thunderbird profile changed during backup; rerun once Thunderbird is fully closed if anything looks incomplete." >&2
            ;;
        *)
            printf '%s\n' "${output}" >&2
            return "${status}"
            ;;
    esac

    printf '%s\n' "${output}"
}

log_activity() {
    local action="$1" log_path="$2"
    printf '%s\t%s\t%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$(hostname -s)" "${action}" >> "${log_path}"
}

format_activity_table() {
    local log_path="$1"
    if [[ ! -f "${log_path}" ]]; then
        printf '  (no activity recorded yet)\n'
        return
    fi
    printf '  %-20s  %-22s  %-22s  %-22s\n' "Computer" "Last Backup" "Last LF Backup" "Last Restore"
    printf '  %-20s  %-22s  %-22s  %-22s\n' "--------------------" "----------------------" "----------------------" "----------------------"
    awk -F'\t' '
        NF == 3 {
            host=$2; action=$3; date=$1
            if (action=="backup"             && (!(host in b)  || date>b[host]))  b[host]=date
            if (action=="localfolders-backup" && (!(host in lf) || date>lf[host])) lf[host]=date
            if (action=="restore"            && (!(host in r)  || date>r[host]))  r[host]=date
            seen[host]=1
        }
        END {
            for (host in seen)
                printf "%s\t%s\t%s\t%s\n", host, (host in b ? b[host] : "-"), (host in lf ? lf[host] : "-"), (host in r ? r[host] : "-")
        }
    ' "${log_path}" | sort | while IFS=$'\t' read -r host bdate lfdate rdate; do
        printf '  %-20s  %-22s  %-22s  %-22s\n' "${host}" "${bdate}" "${lfdate}" "${rdate}"
    done
}

sync_backup_tree() {
    local name="$1"
    local source_dir="${local_staging}/${name}/"
    local target_dir="${pcloud_backup_root}/${name}/"
    local source_marker="${source_dir}${ownership_marker}"
    local target_marker="${target_dir}${ownership_marker}"

    if [[ ! -d "${source_dir}" ]]; then
        return
    fi

    printf 'owner=thunderbird-backup\npath=%s\n' "${name}" > "${source_marker}"

    if [[ -d "${target_dir}" && ! -f "${target_marker}" ]]; then
        case "${name}" in
            thunderbird)
                if [[ ! -f "${target_dir}.backup_manifest" && ! -f "${target_dir}prefs.js" ]]; then
                    echo "Error: Refusing destructive sync to unmarked directory: ${target_dir}" >&2
                    exit 1
                fi
                ;;
            profile-root)
                if [[ ! -f "${target_dir}profiles.ini" ]]; then
                    echo "Error: Refusing destructive sync to unmarked directory: ${target_dir}" >&2
                    exit 1
                fi
                ;;
            metadata)
                if [[ ! -f "${target_dir}restore-context.env" ]]; then
                    echo "Error: Refusing destructive sync to unmarked directory: ${target_dir}" >&2
                    exit 1
                fi
                ;;
            *)
                echo "Error: Refusing destructive sync to unmarked directory: ${target_dir}" >&2
                exit 1
                ;;
        esac
        printf 'owner=thunderbird-backup\npath=%s\n' "${name}" > "${target_marker}"
        echo "Marked existing backup-owned directory: ${target_dir}"
    fi

    mkdir -p "${target_dir}"
    run_rsync_capture rsync -r --times --delete --no-perms --no-owner --no-group --no-devices --no-specials "${source_dir}" "${target_dir}"
}

get_manifest_date() {
    local manifest_file="$1"
    if [[ -f "${manifest_file}" ]]; then
        awk -F= '/^date=/{print $2; exit}' "${manifest_file}"
    fi
}

for arg in "$@"; do
    case "${arg}" in
        --dry-run) dry_run=true ;;
        --self-test) self_test=true ;;
        --force-non-review) force_non_review=true ;;
        backup|init-profile-repo|profile-snapshots) subcmd="${arg}" ;;
        -h|--help) usage; exit 0 ;;
        *)
            echo "Error: Unknown option: ${arg}" >&2
            usage >&2
            exit 1
            ;;
    esac
done

setup_self_test() {
    local root
    self_test_root=$(mktemp -d)
    root="${self_test_root}"
    trap 'rm -rf "${self_test_root}"' EXIT
    tb_type="SelfTest"
    tb_version="self-test"
    tb_dir="${root}/tb"
    backup_root="${root}/backup/${backup_root_rel}"
    dest="${backup_root}/thunderbird/"
    log_file="${backup_root}/backup.log"

    mkdir -p "${tb_dir}/test.profile"
    cat <<EOF > "${tb_dir}/profiles.ini"
[Profile0]
Name=SelfTest
IsRelative=1
Path=test.profile
Default=1

[InstallSelfTest]
Default=test.profile
Locked=1
EOF
    echo 'user_pref("mail.server.server1.hostname", "example.com");' > "${tb_dir}/test.profile/prefs.js"
}

pcloud_backup_root=""
local_staging=""
pcloud_writable=true

if "${self_test}"; then
    setup_self_test
else
    if [[ -d "${pcloud_mount}" ]]; then
        if ! "${dry_run}" && [[ ! -w "${pcloud_mount}" ]]; then
            pcloud_writable=false
        fi
        pcloud_backup_root="${pcloud_mount}/${backup_root_rel}"
    elif [[ -d "${pcloud_drive}" ]]; then
        pcloud_backup_root="${pcloud_drive}/${backup_root_rel}"
    else
        echo "Error: No pCloud mount or drive found (${pcloud_mount} or ${pcloud_drive})." >&2
        exit 1
    fi

    local_staging="${HOME}/.local/share/thunderbird-backup"
    backup_root="${local_staging}"
    dest="${backup_root}/thunderbird/"
    log_file="${backup_root}/backup.log"
fi

profile_root_dest="${backup_root}/profile-root/"
metadata_dest="${backup_root}/metadata/"
profile_restic_repo="${pcloud_backup_root:+${pcloud_backup_root}/${default_profile_repo_subdir}}"
restic_password_file="${pcloud_backup_root:+${pcloud_backup_root}/.restic-password}"

if [[ "${subcmd}" == "backup" && "${self_test}" != true && -f "${NO_REVIEW_FILE}" && "${force_non_review}" != true ]]; then
    non_review_localfolders_only=true
fi

if [[ "${subcmd}" == "init-profile-repo" ]]; then
    if [[ -z "${profile_restic_repo}" ]]; then
        echo "Error: No pCloud mount found for profile restic repository." >&2
        exit 1
    fi
    if ! command -v restic >/dev/null 2>&1; then
        echo "Error: restic not found." >&2
        exit 1
    fi
    if "${dry_run}"; then
        echo "Would initialize profile restic repository: ${profile_restic_repo}"
    else
        if ! have_restic_password; then
            echo "Error: Restic password unavailable." >&2
            echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
            exit 1
        fi
        mkdir -p "${profile_restic_repo}"
        run_profile_restic "${profile_restic_repo}" init
        echo "Profile restic repository initialized: ${profile_restic_repo}"
    fi
    exit 0
fi

if [[ "${subcmd}" == "profile-snapshots" ]]; then
    if [[ -z "${profile_restic_repo}" ]]; then
        echo "Error: No pCloud mount found for profile restic repository." >&2
        exit 1
    fi
    if ! command -v restic >/dev/null 2>&1; then
        echo "Error: restic not found." >&2
        exit 1
    fi
    if [[ ! -f "${profile_restic_repo}/config" ]]; then
        echo "Error: Profile restic repository missing: ${profile_restic_repo}" >&2
        echo "Run: $(basename "$0") init-profile-repo" >&2
        exit 1
    fi
    if ! have_restic_password; then
        echo "Error: Restic password unavailable." >&2
        echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
        exit 1
    fi
    run_profile_restic "${profile_restic_repo}" snapshots --tag thunderbird-profile
    exit 0
fi

run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 5s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

find_flatpak_thunderbird() {
    local app_id
    for app_id in org.mozilla.thunderbird_esr org.mozilla.thunderbird org.mozilla.Thunderbird; do
        if command -v flatpak &>/dev/null && run_quick_check flatpak info "${app_id}"; then
            printf '%s\n' "${app_id}"
            return 0
        fi
    done
    return 1
}

# Detect Thunderbird installation and set profile directory accordingly
if ! "${self_test}"; then
    if TB_FLATPAK_APP_ID=$(find_flatpak_thunderbird); then
        tb_type="Flatpak"
        tb_dir="${HOME}/.var/app/${TB_FLATPAK_APP_ID}/.thunderbird"
    elif command -v snap &>/dev/null && run_quick_check snap list thunderbird; then
        tb_type="Snap"
        tb_dir="${HOME}/snap/thunderbird/common/.thunderbird"
    elif command -v thunderbird &>/dev/null; then
        tb_type="System"
        tb_dir="${HOME}/.thunderbird"
    else
        echo "Error: No Thunderbird installation found" >&2
        exit 1
    fi
fi

get_tb_version() {
    local detected_type="$1"
    local version="unknown"
    case "${detected_type}" in
        Flatpak)
            if command -v timeout >/dev/null 2>&1; then
                version=$(timeout 5s flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            else
                version=$(flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            fi
            ;;
        *)
            if command -v thunderbird >/dev/null 2>&1; then
                version=$(thunderbird --version 2>/dev/null | awk '{print $2}' || true)
            fi
            ;;
    esac
    [[ -n "${version}" ]] || version="unknown"
    echo "${version}"
}

if ! "${self_test}"; then
    tb_version=$(get_tb_version "${tb_type}")
fi

if "${non_review_localfolders_only}"; then
    echo "Thunderbird Backup Status"
    echo "  Thunderbird:             ${tb_type}"
    echo "  Version:                 ${tb_version}"
    echo "  Role:                    non-review"
    echo "  Shared profile backup:   skipped"
    echo "  Local Folders backup:    will run"
    echo
    echo "Backup Plan"
    echo "  Command:                 ${SCRIPT_DIR}/thunderbird-localfolders-backup"
    echo "  Override:                use --force-non-review to publish shared profile backup from this machine"
    echo
    set +e
    if "${dry_run}"; then
        "${SCRIPT_DIR}/thunderbird-localfolders-backup" --dry-run
    else
        "${SCRIPT_DIR}/thunderbird-localfolders-backup"
    fi
    lf_status=$?
    set -e
    if [[ "${lf_status}" -ne 0 ]]; then
        echo
        echo "Local Folders backup failed."
        echo "If this is a new repository, initialize it once with:"
        echo "  thunderbird-localfolders-backup init"
    fi
    exit "${lf_status}"
fi

profiles_ini="${tb_dir}/profiles.ini"

if [[ ! -f "${profiles_ini}" ]]; then
    echo "Error: ${profiles_ini} not found" >&2
    exit 1
fi

# Determine active profile path.
profile_path=$(python3 "${SCRIPT_DIR}/thunderbird_profile.py" "${tb_dir}") || {
    echo "Error: Could not determine active Thunderbird profile from ${tb_dir}/profiles.ini" >&2
    exit 1
}
active_profile=$(basename "${profile_path}")

if [[ ! -d "${profile_path}" ]]; then
    echo "Error: Thunderbird profile directory not found: ${profile_path}" >&2
    exit 1
fi

src="${profile_path}/"

check_thunderbird_running() {
    pgrep -x thunderbird &>/dev/null || \
    pgrep -x thunderbird-bin &>/dev/null || \
    { command -v flatpak &>/dev/null && flatpak ps --columns=application 2>/dev/null | grep -Eq '^(org\.mozilla\.thunderbird_esr|org\.mozilla\.thunderbird|org\.mozilla\.Thunderbird)$'; }
}

if [[ ! -f "${src}/prefs.js" ]]; then
    echo "Error: Source does not look like a Thunderbird profile: ${src}" >&2
    exit 1
fi

if ! "${self_test}" && check_thunderbird_running; then
    thunderbird_status="running"
else
    thunderbird_status="not running"
fi

local_manifest_date=$(get_manifest_date "${dest}/.backup_manifest")
pcloud_manifest_date=""
if [[ -n "${pcloud_backup_root}" ]]; then
    pcloud_manifest_date=$(get_manifest_date "${pcloud_backup_root}/thunderbird/.backup_manifest")
fi

profile_snapshot_plan="not configured"
if [[ -n "${profile_restic_repo}" ]]; then
    if [[ -f "${profile_restic_repo}/config" ]]; then
        if command -v restic >/dev/null 2>&1 && have_restic_password; then
            profile_snapshot_plan="${profile_restic_repo}"
        elif ! command -v restic >/dev/null 2>&1; then
            profile_snapshot_plan="skipped (restic not installed)"
        else
            profile_snapshot_plan="skipped (password unavailable)"
        fi
    else
        profile_snapshot_plan="skipped (repo missing; run thunderbird-backup init-profile-repo)"
    fi
fi

echo "Thunderbird Backup Status"
echo "  Thunderbird:        ${tb_type}"
echo "  Version:            ${tb_version}"
echo "  Active profile:     ${active_profile}"
echo "  Thunderbird status: ${thunderbird_status}"
echo "  Last local backup:  ${local_manifest_date:-(none)}"
if [[ -n "${pcloud_backup_root}" ]]; then
    echo "  Last pCloud backup: ${pcloud_manifest_date:-(none)}"
    if "${pcloud_writable}"; then
        echo "  pCloud writable:    yes"
    else
        echo "  pCloud writable:    no (${pcloud_mount})"
    fi
fi
echo
echo "Backup Plan"
if "${dry_run}"; then
    echo "  Mode:               Dry run only; no files will be changed."
    echo "  Profile scan:       ${src}"
    echo "  Compare against:    ${dest}"
else
    echo "  Source:             ${src}"
    echo "  Local backup:       ${dest}"
    if [[ -n "${pcloud_backup_root}" ]]; then
        echo "  pCloud sync:        thunderbird/, profile-root/, metadata/, backup.log"
    fi
    echo "  Profile snapshot:   ${profile_snapshot_plan}"
    echo "  Profile root copy:  ${profile_root_dest}"
    echo "  Metadata:           ${metadata_dest}"
    echo "  Deletes:            Removed files are deleted only inside backup-owned directories."
fi
echo

if ! "${dry_run}" && ! "${self_test}"; then
    read -rp "Continue with backup? [y/N] " confirm
    if [[ "${confirm}" != [yY] ]]; then
        echo "Backup cancelled."
        exit 0
    fi
    if ! "${pcloud_writable}"; then
        echo "Error: ${pcloud_mount} is not writable." >&2
        exit 1
    fi
fi

if ! "${self_test}" && ! "${dry_run}" && check_thunderbird_running; then
    echo "Thunderbird is running."
    read -rp "Kill Thunderbird before backing up? [y/N] " confirm_kill
    if [[ "${confirm_kill}" != [yY] ]]; then
        echo "Error: Please close Thunderbird before backing up." >&2
        exit 1
    fi
    pkill -x thunderbird 2>/dev/null || true
    if [[ "${tb_type}" == "Flatpak" ]]; then
        flatpak kill "${TB_FLATPAK_APP_ID}" 2>/dev/null || true
    fi
    sleep 2
    if check_thunderbird_running; then
        echo "Error: Thunderbird is still running. Please close it manually and retry." >&2
        exit 1
    fi
fi

start_time=$(date +%s)
tmp_dry_dest=""
rsync_dest="${dest}"
if "${dry_run}" && [[ ! -d "${dest}" ]]; then
    tmp_dry_dest=$(mktemp -d)
    rsync_dest="${tmp_dry_dest}/"
fi

if "${dry_run}"; then
    rsync_output=$(run_rsync_capture rsync -a --copy-links --exclude='lock' --exclude='.parentlock' --delete --delete-excluded --stats --dry-run "${src}" "${rsync_dest}")
else
    mkdir -p "${dest}"
    rsync_output=$(run_rsync_capture rsync -a --copy-links --exclude='lock' --exclude='.parentlock' --delete --delete-excluded --stats "${src}" "${dest}")
    mkdir -p "${profile_root_dest}" "${metadata_dest}"
    for root_file in profiles.ini installs.ini; do
        if [[ -f "${tb_dir}/${root_file}" ]]; then
            cp -a "${tb_dir}/${root_file}" "${profile_root_dest}/${root_file}"
        fi
    done
    {
        echo "date=$(date '+%Y-%m-%d %H:%M:%S')"
        echo "home=${HOME}"
        echo "thunderbird=${tb_type}"
        echo "thunderbird_version=${tb_version}"
        echo "profile=${active_profile}"
        echo "profile_root=${tb_dir}"
        echo "profile_path=${profile_path}"
    } > "${metadata_dest}/restore-context.env"
    if [[ "${tb_type}" == "Flatpak" ]] && command -v flatpak >/dev/null 2>&1; then
        flatpak info "${TB_FLATPAK_APP_ID}" > "${metadata_dest}/flatpak-info.txt" 2>&1 || true
        flatpak info --show-permissions "${TB_FLATPAK_APP_ID}" > "${metadata_dest}/flatpak-permissions.txt" 2>&1 || true
        flatpak override --user --show "${TB_FLATPAK_APP_ID}" > "${metadata_dest}/flatpak-override-user.txt" 2>&1 || true
        flatpak override --system --show "${TB_FLATPAK_APP_ID}" > "${metadata_dest}/flatpak-override-system.txt" 2>&1 || true
        flatpak remotes --columns=name,url,options > "${metadata_dest}/flatpak-remotes.txt" 2>&1 || true
        flatpak list --app --columns=application,branch,origin,installation,version > "${metadata_dest}/flatpak-apps.txt" 2>&1 || true
        flatpak list --runtime --columns=application,branch,origin,installation,version > "${metadata_dest}/flatpak-runtimes.txt" 2>&1 || true
        flatpak permissions > "${metadata_dest}/flatpak-portal-permissions.txt" 2>&1 || true
        nm_src="${HOME}/.mozilla/native-messaging-hosts"
        if [[ -d "${nm_src}" ]]; then
            mkdir -p "${metadata_dest}/native-messaging-hosts"
            cp -a "${nm_src}/." "${metadata_dest}/native-messaging-hosts/"
        fi
    fi
    if command -v xdg-mime >/dev/null 2>&1; then
        {
            echo "x-scheme-handler/mailto=$(xdg-mime query default x-scheme-handler/mailto 2>/dev/null || true)"
            echo "message/rfc822=$(xdg-mime query default message/rfc822 2>/dev/null || true)"
            echo "text/calendar=$(xdg-mime query default text/calendar 2>/dev/null || true)"
            echo "text/vcard=$(xdg-mime query default text/vcard 2>/dev/null || true)"
        } > "${metadata_dest}/xdg-mime-defaults.txt"
    fi
fi
[[ -n "${tmp_dry_dest}" ]] && rm -rf "${tmp_dry_dest}"
end_time=$(date +%s)
elapsed=$(( end_time - start_time ))

# Format duration
if (( elapsed >= 3600 )); then
    duration="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m $(( elapsed % 60 ))s"
elif (( elapsed >= 60 )); then
    duration="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"
else
    duration="${elapsed}s"
fi

# Parse rsync stats
files_transferred=$(echo "${rsync_output}" | awk '/Number of regular files transferred:/{print $NF}')
total_files=$(echo "${rsync_output}" | awk '/Number of files:/{print $4}')
total_files="${total_files//[^0-9]/}"
total_size=$(echo "${rsync_output}" | awk '/Total file size:/{print $4, $5}')
sent=$(echo "${rsync_output}" | awk '/Total bytes sent:/{if ($5!="") print $4" "$5; else print $4}')
profile_size=$(du -sh "${src}" | cut -f1)
if "${dry_run}"; then
    backup_size="n/a"
    file_count="${total_files:-n/a}"
else
    backup_size=$(du -sh "${backup_root}" | cut -f1)
    file_count=$(find "${dest}" -type f | wc -l)
fi

# Write simple manifest for restore validation
if ! "${dry_run}"; then
    manifest_file="${dest}/.backup_manifest"
    cat <<EOF > "${manifest_file}"
date=$(date '+%Y-%m-%d %H:%M:%S')
thunderbird=${tb_type}
thunderbird_version=${tb_version}
profile=${active_profile}
source=${src}
destination=${dest}
profile_root_backup=${profile_root_dest}
metadata_backup=${metadata_dest}
file_count=${file_count}
profile_size=${profile_size}
EOF
fi

# Report
if "${dry_run}"; then
    mode_suffix="(dry run) "
else
    mode_suffix=""
fi

report=$(cat <<EOF
==============================
  Backup Report
==============================
  Date:               $(date '+%Y-%m-%d %H:%M:%S')
  Thunderbird:        ${tb_type}
  Version:            ${tb_version}
  Profile:            ${active_profile}
  Source:             ${src}
  Local backup:       ${dest}
  pCloud backup:      ${pcloud_backup_root:+${pcloud_backup_root}/thunderbird/}
  Duration:           ${duration}
  Files transferred:  ${files_transferred}
  Data transferred:   ${sent}
  Total files:        ${file_count}
  Total backup size:  ${backup_size}
  Profile size:       ${profile_size}
==============================
  Backup ${mode_suffix}complete.
==============================
EOF
)

echo "${report}"
if ! "${dry_run}"; then
    profile_snapshot_status="Skipped"
    if [[ -n "${profile_restic_repo}" ]]; then
        if [[ -f "${profile_restic_repo}/config" ]] && command -v restic >/dev/null 2>&1 && have_restic_password; then
            echo "Creating profile restic snapshot..."
            run_profile_restic "${profile_restic_repo}" backup \
                --tag thunderbird \
                --tag thunderbird-profile \
                --host "$(hostname -s)" \
                "${src}"
            profile_snapshot_status="Complete"
        elif [[ ! -f "${profile_restic_repo}/config" ]]; then
            profile_snapshot_status="Skipped (repo missing)"
            echo "Profile restic snapshot skipped: repository missing (${profile_restic_repo})."
            echo "Run: thunderbird-backup init-profile-repo"
        elif ! command -v restic >/dev/null 2>&1; then
            profile_snapshot_status="Skipped (restic not installed)"
            echo "Profile restic snapshot skipped: restic not installed."
        else
            profile_snapshot_status="Skipped (password unavailable)"
            echo "Profile restic snapshot skipped: password unavailable (${restic_password_file})."
        fi
        echo
    fi
    echo "${report}" >> "${log_file}"
    if [[ -n "${pcloud_backup_root}" ]]; then
        echo "Syncing local backup to pCloud..."
        mkdir -p "${pcloud_backup_root}"
        sync_backup_tree thunderbird
        sync_backup_tree profile-root
        sync_backup_tree metadata
        run_rsync_capture rsync --times --no-perms --no-owner --no-group --no-devices --no-specials "${log_file}" "${pcloud_backup_root}/backup.log"
        echo "pCloud sync complete."
        if ! "${self_test}"; then
            log_activity "backup" "${pcloud_backup_root}/activity.log"
            echo
            echo "  Computer Activity"
            format_activity_table "${pcloud_backup_root}/activity.log"
        fi
    fi
    echo "NOTE: pCloud must finish syncing before this backup is valid for restore"
    echo "      on another machine. Wait for pCloud to show idle before restoring."
fi
