#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
default_profile_repo_subdir="profile-restic"
aux_dir_default="${HOME}/.local/share/thunderbird-backup/aux"
activity_fallback="${HOME}/.local/share/thunderbird-backup/activity.log.fallback"
dry_run=false
self_test=false
self_test_root=""
subcmd="backup"
force_non_review=false
NO_REVIEW_FILE="${HOME}/.config/tbblock/no-review"
non_review_localfolders_only=false

usage() {
    cat <<EOF
Usage: $(basename "$0") [--dry-run] [--self-test] [--force-non-review] [SUBCOMMAND]

Subcommands (default: backup):
  backup             Create a new profile restic snapshot
  init-profile-repo  Initialize the profile restic repository
  profile-snapshots  List profile restic snapshots

Options:
  --dry-run    Show what restic would back up without writing
  --self-test  Run a safe self-test against a temporary restic repository
  --force-non-review
               Allow publishing the shared profile backup from a non-review machine
  -h, --help   Show this help
EOF
}

have_restic_password() {
    [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" || -f "${restic_password_file:-}" ]]
}

run_profile_restic() {
    local repo="$1"
    shift

    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic "$@"
    else
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic "$@"
    fi
}

log_activity() {
    local action="$1" status="$2" detail="$3" log_path="$4"
    local line
    line=$(printf '%s\t%s\t%s\t%s\t%s' "$(date '+%Y-%m-%d %H:%M:%S')" "$(hostname -s)" "${action}" "${status}" "${detail}")
    if [[ -n "${log_path}" ]] && printf '%s\n' "${line}" >> "${log_path}" 2>/dev/null; then
        return 0
    fi
    mkdir -p "$(dirname "${activity_fallback}")"
    printf '%s\n' "${line}" >> "${activity_fallback}"
    echo "Warning: could not write activity log to ${log_path:-(unset)}; appended to ${activity_fallback}" >&2
    return 0
}

format_activity_table() {
    local log_path="$1"
    if [[ ! -f "${log_path}" ]]; then
        printf '  (no activity recorded yet)\n'
        return
    fi
    printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "Computer" "Last Backup" "Last LF Backup" "Last Restore" "Status"
    printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "--------------------" "----------------------" "----------------------" "----------------------" "----------"
    awk -F'\t' '
        NF >= 3 {
            host=$2; action=$3; date=$1
            status=(NF >= 4 ? $4 : "ok")
            if (action=="backup"             && (!(host in b)  || date>b[host]))  { b[host]=date;  bs[host]=status }
            if (action=="localfolders-backup" && (!(host in lf) || date>lf[host])) { lf[host]=date; ls[host]=status }
            if (action=="restore"            && (!(host in r)  || date>r[host]))  { r[host]=date;  rs[host]=status }
            if (!(host in last) || date>last[host]) { last[host]=date; lasts[host]=status }
            seen[host]=1
        }
        END {
            for (host in seen)
                printf "%s\t%s\t%s\t%s\t%s\n", host,
                    (host in b ? b[host] : "-"),
                    (host in lf ? lf[host] : "-"),
                    (host in r ? r[host] : "-"),
                    (host in lasts ? lasts[host] : "-")
        }
    ' "${log_path}" | sort | while IFS=$'\t' read -r host bdate lfdate rdate status; do
        printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "${host}" "${bdate}" "${lfdate}" "${rdate}" "${status}"
    done
}

cleanup_legacy_staging() {
    # Remove obsolete artifacts from the pre-restic-only rsync-mirror design.
    local legacy_root="${HOME}/.local/share/thunderbird-backup"
    rm -rf "${legacy_root}/thunderbird" \
           "${legacy_root}/profile-root" \
           "${legacy_root}/metadata"
    rm -f "${legacy_root}/backup.log"
}

prepare_aux_staging() {
    local aux="$1"
    local tb_dir="$2"
    local tb_type_local="$3"
    local tb_version_local="$4"
    local active_profile_local="$5"
    local profile_path_local="$6"
    local flatpak_app_id="${7:-}"

    rm -rf "${aux}"
    mkdir -p "${aux}/profile-root" "${aux}/metadata"

    for root_file in profiles.ini installs.ini; do
        if [[ -f "${tb_dir}/${root_file}" ]]; then
            cp -a "${tb_dir}/${root_file}" "${aux}/profile-root/${root_file}"
        fi
    done

    {
        echo "date=$(date '+%Y-%m-%d %H:%M:%S')"
        echo "home=${HOME}"
        echo "thunderbird=${tb_type_local}"
        echo "thunderbird_version=${tb_version_local}"
        echo "profile=${active_profile_local}"
        echo "profile_root=${tb_dir}"
        echo "profile_path=${profile_path_local}"
    } > "${aux}/metadata/restore-context.env"

    if [[ "${tb_type_local}" == "Flatpak" ]] && command -v flatpak >/dev/null 2>&1 && [[ -n "${flatpak_app_id}" ]]; then
        flatpak info "${flatpak_app_id}" > "${aux}/metadata/flatpak-info.txt" 2>&1 || true
        flatpak info --show-permissions "${flatpak_app_id}" > "${aux}/metadata/flatpak-permissions.txt" 2>&1 || true
        flatpak override --user --show "${flatpak_app_id}" > "${aux}/metadata/flatpak-override-user.txt" 2>&1 || true
        flatpak override --system --show "${flatpak_app_id}" > "${aux}/metadata/flatpak-override-system.txt" 2>&1 || true
        flatpak remotes --columns=name,url,options > "${aux}/metadata/flatpak-remotes.txt" 2>&1 || true
        flatpak list --app --columns=application,branch,origin,installation,version > "${aux}/metadata/flatpak-apps.txt" 2>&1 || true
        flatpak list --runtime --columns=application,branch,origin,installation,version > "${aux}/metadata/flatpak-runtimes.txt" 2>&1 || true
        flatpak permissions > "${aux}/metadata/flatpak-portal-permissions.txt" 2>&1 || true
        local nm_src="${HOME}/.mozilla/native-messaging-hosts"
        if [[ -d "${nm_src}" ]]; then
            mkdir -p "${aux}/metadata/native-messaging-hosts"
            cp -a "${nm_src}/." "${aux}/metadata/native-messaging-hosts/"
        fi
    fi
    if command -v xdg-mime >/dev/null 2>&1; then
        {
            echo "x-scheme-handler/mailto=$(xdg-mime query default x-scheme-handler/mailto 2>/dev/null || true)"
            echo "message/rfc822=$(xdg-mime query default message/rfc822 2>/dev/null || true)"
            echo "text/calendar=$(xdg-mime query default text/calendar 2>/dev/null || true)"
            echo "text/vcard=$(xdg-mime query default text/vcard 2>/dev/null || true)"
        } > "${aux}/metadata/xdg-mime-defaults.txt"
    fi
}

latest_profile_snapshot_short_id() {
    local repo="$1"
    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic snapshots \
            --tag thunderbird-profile --host "$(hostname -s)" --latest 1 --json 2>/dev/null
    else
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic snapshots \
            --tag thunderbird-profile --host "$(hostname -s)" --latest 1 --json 2>/dev/null
    fi | python3 -c '
import json, sys
try:
    snaps = json.load(sys.stdin)
except Exception:
    sys.exit(0)
if snaps:
    s = snaps[-1]
    print(s.get("short_id") or (s.get("id") or "")[:8])
'
}

for arg in "$@"; do
    case "${arg}" in
        --dry-run) dry_run=true ;;
        --self-test) self_test=true ;;
        --force-non-review) force_non_review=true ;;
        backup|init-profile-repo|profile-snapshots) subcmd="${arg}" ;;
        -h|--help) usage; exit 0 ;;
        *)
            echo "Error: Unknown option: ${arg}" >&2
            usage >&2
            exit 1
            ;;
    esac
done

setup_self_test() {
    self_test_root=$(mktemp -d)
    trap 'rm -rf "${self_test_root}"' EXIT
    tb_type="SelfTest"
    tb_version="self-test"
    tb_dir="${self_test_root}/tb"
    aux_dir="${self_test_root}/aux"
    pcloud_backup_root="${self_test_root}/backup/${backup_root_rel}"
    profile_restic_repo="${pcloud_backup_root}/${default_profile_repo_subdir}"
    restic_password_file="${pcloud_backup_root}/.restic-password"
    activity_log="${pcloud_backup_root}/activity.log"

    mkdir -p "${tb_dir}/test.profile" "${pcloud_backup_root}"
    cat <<EOF > "${tb_dir}/profiles.ini"
[Profile0]
Name=SelfTest
IsRelative=1
Path=test.profile
Default=1

[InstallSelfTest]
Default=test.profile
Locked=1
EOF
    echo 'user_pref("mail.server.server1.hostname", "example.com");' > "${tb_dir}/test.profile/prefs.js"
    printf 'self-test-password\n' > "${restic_password_file}"
    chmod 600 "${restic_password_file}"
    RESTIC_REPOSITORY="${profile_restic_repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic init >/dev/null
}

pcloud_backup_root=""
pcloud_writable=true
aux_dir="${aux_dir_default}"

if "${self_test}"; then
    setup_self_test
else
    if [[ -d "${pcloud_mount}" ]]; then
        if ! "${dry_run}" && [[ ! -w "${pcloud_mount}" ]]; then
            pcloud_writable=false
        fi
        pcloud_backup_root="${pcloud_mount}/${backup_root_rel}"
    elif [[ -d "${pcloud_drive}" ]]; then
        pcloud_backup_root="${pcloud_drive}/${backup_root_rel}"
    else
        echo "Error: No pCloud mount or drive found (${pcloud_mount} or ${pcloud_drive})." >&2
        exit 1
    fi
    profile_restic_repo="${pcloud_backup_root}/${default_profile_repo_subdir}"
    restic_password_file="${pcloud_backup_root}/.restic-password"
    activity_log="${pcloud_backup_root}/activity.log"
fi

if [[ "${subcmd}" == "backup" && "${self_test}" != true && -f "${NO_REVIEW_FILE}" && "${force_non_review}" != true ]]; then
    non_review_localfolders_only=true
fi

if [[ "${subcmd}" == "init-profile-repo" ]]; then
    if [[ -z "${profile_restic_repo}" ]]; then
        echo "Error: No pCloud mount found for profile restic repository." >&2
        exit 1
    fi
    if ! command -v restic >/dev/null 2>&1; then
        echo "Error: restic not found." >&2
        exit 1
    fi
    if "${dry_run}"; then
        echo "Would initialize profile restic repository: ${profile_restic_repo}"
    else
        if ! have_restic_password; then
            echo "Error: Restic password unavailable." >&2
            echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
            exit 1
        fi
        mkdir -p "${profile_restic_repo}"
        run_profile_restic "${profile_restic_repo}" init
        echo "Profile restic repository initialized: ${profile_restic_repo}"
    fi
    exit 0
fi

if [[ "${subcmd}" == "profile-snapshots" ]]; then
    if [[ -z "${profile_restic_repo}" ]]; then
        echo "Error: No pCloud mount found for profile restic repository." >&2
        exit 1
    fi
    if ! command -v restic >/dev/null 2>&1; then
        echo "Error: restic not found." >&2
        exit 1
    fi
    if [[ ! -f "${profile_restic_repo}/config" ]]; then
        echo "Error: Profile restic repository missing: ${profile_restic_repo}" >&2
        echo "Run: $(basename "$0") init-profile-repo" >&2
        exit 1
    fi
    if ! have_restic_password; then
        echo "Error: Restic password unavailable." >&2
        echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
        exit 1
    fi
    run_profile_restic "${profile_restic_repo}" snapshots --tag thunderbird-profile
    exit 0
fi

run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 5s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

find_flatpak_thunderbird() {
    local app_id
    for app_id in org.mozilla.thunderbird_esr org.mozilla.thunderbird org.mozilla.Thunderbird; do
        if command -v flatpak &>/dev/null && run_quick_check flatpak info "${app_id}"; then
            printf '%s\n' "${app_id}"
            return 0
        fi
    done
    return 1
}

TB_FLATPAK_APP_ID=""
if ! "${self_test}"; then
    if TB_FLATPAK_APP_ID=$(find_flatpak_thunderbird); then
        tb_type="Flatpak"
        tb_dir="${HOME}/.var/app/${TB_FLATPAK_APP_ID}/.thunderbird"
    elif command -v snap &>/dev/null && run_quick_check snap list thunderbird; then
        tb_type="Snap"
        tb_dir="${HOME}/snap/thunderbird/common/.thunderbird"
    elif command -v thunderbird &>/dev/null; then
        tb_type="System"
        tb_dir="${HOME}/.thunderbird"
    else
        echo "Error: No Thunderbird installation found" >&2
        exit 1
    fi
fi

get_tb_version() {
    local detected_type="$1"
    local version="unknown"
    case "${detected_type}" in
        Flatpak)
            if command -v timeout >/dev/null 2>&1; then
                version=$(timeout 5s flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            else
                version=$(flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            fi
            ;;
        *)
            if command -v thunderbird >/dev/null 2>&1; then
                version=$(thunderbird --version 2>/dev/null | awk '{print $2}' || true)
            fi
            ;;
    esac
    [[ -n "${version}" ]] || version="unknown"
    echo "${version}"
}

if ! "${self_test}"; then
    tb_version=$(get_tb_version "${tb_type}")
fi

if "${non_review_localfolders_only}"; then
    echo "Thunderbird Backup Status"
    echo "  Thunderbird:             ${tb_type}"
    echo "  Version:                 ${tb_version}"
    echo "  Role:                    non-review"
    echo "  Shared profile backup:   skipped"
    echo "  Local Folders backup:    will run"
    echo
    echo "Backup Plan"
    echo "  Command:                 ${SCRIPT_DIR}/thunderbird-localfolders-backup"
    echo "  Override:                use --force-non-review to publish shared profile backup from this machine"
    echo
    set +e
    if "${dry_run}"; then
        "${SCRIPT_DIR}/thunderbird-localfolders-backup" --dry-run
    else
        "${SCRIPT_DIR}/thunderbird-localfolders-backup"
    fi
    lf_status=$?
    set -e
    if [[ "${lf_status}" -ne 0 ]]; then
        echo
        echo "Local Folders backup failed."
        echo "If this is a new repository, initialize it once with:"
        echo "  thunderbird-localfolders-backup init"
    fi
    exit "${lf_status}"
fi

profiles_ini="${tb_dir}/profiles.ini"

if [[ ! -f "${profiles_ini}" ]]; then
    echo "Error: ${profiles_ini} not found" >&2
    exit 1
fi

profile_path=$(python3 "${SCRIPT_DIR}/thunderbird_profile.py" "${tb_dir}") || {
    echo "Error: Could not determine active Thunderbird profile from ${tb_dir}/profiles.ini" >&2
    exit 1
}
active_profile=$(basename "${profile_path}")

if [[ ! -d "${profile_path}" ]]; then
    echo "Error: Thunderbird profile directory not found: ${profile_path}" >&2
    exit 1
fi

check_thunderbird_running() {
    pgrep -x thunderbird &>/dev/null || \
    pgrep -x thunderbird-bin &>/dev/null || \
    { command -v flatpak &>/dev/null && flatpak ps --columns=application 2>/dev/null | grep -Eq '^(org\.mozilla\.thunderbird_esr|org\.mozilla\.thunderbird|org\.mozilla\.Thunderbird)$'; }
}

if [[ ! -f "${profile_path}/prefs.js" ]]; then
    echo "Error: Source does not look like a Thunderbird profile: ${profile_path}" >&2
    exit 1
fi

if ! "${self_test}" && check_thunderbird_running; then
    thunderbird_status="running"
else
    thunderbird_status="not running"
fi

profile_snapshot_plan="not configured"
if [[ -n "${profile_restic_repo}" ]]; then
    if [[ -f "${profile_restic_repo}/config" ]]; then
        if command -v restic >/dev/null 2>&1 && have_restic_password; then
            profile_snapshot_plan="${profile_restic_repo}"
        elif ! command -v restic >/dev/null 2>&1; then
            profile_snapshot_plan="unavailable (restic not installed)"
        else
            profile_snapshot_plan="unavailable (password missing)"
        fi
    else
        profile_snapshot_plan="repo missing (run: $(basename "$0") init-profile-repo)"
    fi
fi

echo "Thunderbird Backup Status"
echo "  Thunderbird:        ${tb_type}"
echo "  Version:            ${tb_version}"
echo "  Active profile:     ${active_profile}"
echo "  Thunderbird status: ${thunderbird_status}"
echo "  Profile snapshot:   ${profile_snapshot_plan}"
echo "  Aux staging:        ${aux_dir}"
if [[ -n "${pcloud_backup_root}" ]] && ! "${self_test}"; then
    if "${pcloud_writable}"; then
        echo "  pCloud writable:    yes"
    else
        echo "  pCloud writable:    no (${pcloud_mount})"
    fi
fi
echo
echo "Backup Plan"
if "${dry_run}"; then
    echo "  Mode:               Dry run; restic will walk the profile and report what would be uploaded."
    echo "  Profile path:       ${profile_path}"
    echo "  Aux staging:        ${aux_dir}"
else
    echo "  Profile path:       ${profile_path}"
    echo "  Aux staging:        ${aux_dir}"
    echo "  Snapshot repo:      ${profile_snapshot_plan}"
fi
echo

if ! "${dry_run}" && ! "${self_test}"; then
    read -rp "Continue with backup? [y/N] " confirm
    if [[ "${confirm}" != [yY] ]]; then
        echo "Backup cancelled."
        log_activity "backup" "cancelled" "user-declined" "${activity_log}"
        exit 0
    fi
    if ! "${pcloud_writable}"; then
        echo "Error: ${pcloud_mount} is not writable." >&2
        log_activity "backup" "error" "pcloud-not-writable" "${activity_log}"
        exit 1
    fi
fi

if ! "${self_test}" && ! "${dry_run}" && check_thunderbird_running; then
    echo "Thunderbird is running."
    read -rp "Kill Thunderbird before backing up? [y/N] " confirm_kill
    if [[ "${confirm_kill}" != [yY] ]]; then
        echo "Error: Please close Thunderbird before backing up." >&2
        log_activity "backup" "cancelled" "thunderbird-running" "${activity_log}"
        exit 1
    fi
    pkill -x thunderbird 2>/dev/null || true
    if [[ "${tb_type}" == "Flatpak" ]]; then
        flatpak kill "${TB_FLATPAK_APP_ID}" 2>/dev/null || true
    fi
    sleep 2
    if check_thunderbird_running; then
        echo "Error: Thunderbird is still running. Please close it manually and retry." >&2
        log_activity "backup" "error" "thunderbird-still-running" "${activity_log}"
        exit 1
    fi
fi

if [[ -z "${profile_restic_repo}" ]] || [[ ! -f "${profile_restic_repo}/config" ]]; then
    echo "Error: Profile restic repository missing: ${profile_restic_repo:-(unset)}" >&2
    echo "Run: $(basename "$0") init-profile-repo" >&2
    log_activity "backup" "error" "repo-missing" "${activity_log}"
    exit 1
fi
if ! command -v restic >/dev/null 2>&1; then
    echo "Error: restic not found." >&2
    log_activity "backup" "error" "restic-not-installed" "${activity_log}"
    exit 1
fi
if ! have_restic_password; then
    echo "Error: Restic password unavailable." >&2
    echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
    log_activity "backup" "error" "no-password" "${activity_log}"
    exit 1
fi

cleanup_legacy_staging

start_time=$(date +%s)

prepare_aux_staging "${aux_dir}" "${tb_dir}" "${tb_type}" "${tb_version}" "${active_profile}" "${profile_path}" "${TB_FLATPAK_APP_ID}"

backup_args=(
    backup
    --tag thunderbird
    --tag thunderbird-profile
    --tag "tb-type:${tb_type}"
    --tag "tb-version:${tb_version}"
    --host "$(hostname -s)"
    "${profile_path}"
    "${aux_dir}"
)
"${dry_run}" && backup_args+=(--dry-run)

set +e
run_profile_restic "${profile_restic_repo}" "${backup_args[@]}"
restic_status=$?
set -e

end_time=$(date +%s)
elapsed=$(( end_time - start_time ))

if (( elapsed >= 3600 )); then
    duration="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m $(( elapsed % 60 ))s"
elif (( elapsed >= 60 )); then
    duration="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"
else
    duration="${elapsed}s"
fi

if [[ "${restic_status}" -ne 0 ]]; then
    echo
    echo "Error: restic backup failed (exit ${restic_status})." >&2
    if ! "${self_test}"; then
        log_activity "backup" "error" "restic-exit-${restic_status}" "${activity_log}"
    fi
    exit "${restic_status}"
fi

snapshot_short_id=""
if ! "${dry_run}"; then
    snapshot_short_id=$(latest_profile_snapshot_short_id "${profile_restic_repo}" || true)
fi

if "${dry_run}"; then
    mode_suffix="(dry run) "
else
    mode_suffix=""
fi

cat <<EOF

==============================
  Backup Report
==============================
  Date:               $(date '+%Y-%m-%d %H:%M:%S')
  Thunderbird:        ${tb_type}
  Version:            ${tb_version}
  Profile:            ${active_profile}
  Profile path:       ${profile_path}
  Snapshot repo:      ${profile_restic_repo}
  Snapshot ID:        ${snapshot_short_id:-(dry run)}
  Duration:           ${duration}
==============================
  Backup ${mode_suffix}complete.
==============================
EOF

if ! "${dry_run}" && ! "${self_test}"; then
    log_activity "backup" "ok" "${snapshot_short_id}" "${activity_log}"
    echo
    echo "  Computer Activity"
    format_activity_table "${activity_log}"
    echo
    echo "NOTE: pCloud must finish syncing before this snapshot is visible to other"
    echo "      machines. Wait for pCloud to show idle before running restore elsewhere."
fi
