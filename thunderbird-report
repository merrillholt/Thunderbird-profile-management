#!/usr/bin/env bash
set -euo pipefail

pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
default_repo_subdir="localfolders-restic"
default_profile_repo_subdir="profile-restic"
local_staging="${HOME}/.local/share/thunderbird-backup"
LAST_RESTORE_FILE="${HOME}/.config/tbblock/last-restore"
NO_REVIEW_FILE="${HOME}/.config/tbblock/no-review"
TB_FLATPAK_APP_ID=""

usage() {
    cat <<EOF
Usage: $(basename "$0")

Show backup, restore, role, and cross-machine activity status for Thunderbird Tools.
EOF
}

for arg in "$@"; do
    case "${arg}" in
        -h|--help) usage; exit 0 ;;
        *)
            echo "Error: Unknown option: ${arg}" >&2
            usage >&2
            exit 1
            ;;
    esac
done

run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 5s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

find_flatpak_thunderbird() {
    local app_id
    for app_id in org.mozilla.thunderbird_esr org.mozilla.thunderbird org.mozilla.Thunderbird; do
        if command -v flatpak &>/dev/null && run_quick_check flatpak info "${app_id}"; then
            printf '%s\n' "${app_id}"
            return 0
        fi
    done
    return 1
}

check_thunderbird_running() {
    pgrep -x thunderbird &>/dev/null || \
    pgrep -x thunderbird-bin &>/dev/null || \
    { command -v flatpak &>/dev/null && flatpak ps --columns=application 2>/dev/null | grep -Eq '^(org\.mozilla\.thunderbird_esr|org\.mozilla\.thunderbird|org\.mozilla\.Thunderbird)$'; }
}

format_activity_table() {
    local log_path="$1"
    shift || true
    local sources=()
    [[ -f "${log_path}" ]] && sources+=("${log_path}")
    local extra
    for extra in "$@"; do
        [[ -f "${extra}" ]] && sources+=("${extra}")
    done

    if [[ ${#sources[@]} -eq 0 ]]; then
        printf '  (no activity recorded yet)\n'
        return
    fi

    printf '  %-20s  %-22s  %-22s  %-22s\n' "Computer" "Last Backup" "Last LF Backup" "Last Restore"
    printf '  %-20s  %-22s  %-22s  %-22s\n' "--------------------" "----------------------" "----------------------" "----------------------"
    awk -F'\t' '
        NF == 3 {
            host=$2; action=$3; date=$1
            if (action=="backup"             && (!(host in b)  || date>b[host]))  b[host]=date
            if (action=="localfolders-backup" && (!(host in lf) || date>lf[host])) lf[host]=date
            if (action=="restore"            && (!(host in r)  || date>r[host]))  r[host]=date
            seen[host]=1
        }
        END {
            for (host in seen)
                printf "%s\t%s\t%s\t%s\n", host, (host in b ? b[host] : "-"), (host in lf ? lf[host] : "-"), (host in r ? r[host] : "-")
        }
    ' "${sources[@]}" | sort | while IFS=$'\t' read -r host bdate lfdate rdate; do
        printf '  %-20s  %-22s  %-22s  %-22s\n' "${host}" "${bdate}" "${lfdate}" "${rdate}"
    done
}

query_lf_snapshots_json() {
    local repo="$1"
    local pw_file="$2"

    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic snapshots --tag local-folders --json 2>/dev/null
    elif [[ -f "${pw_file}" ]]; then
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${pw_file}" restic snapshots --tag local-folders --json 2>/dev/null
    else
        RESTIC_REPOSITORY="${repo}" restic snapshots --tag local-folders --json 2>/dev/null
    fi
}

query_profile_snapshots_json() {
    local repo="$1"
    local pw_file="$2"

    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic snapshots --tag thunderbird-profile --json 2>/dev/null
    elif [[ -f "${pw_file}" ]]; then
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${pw_file}" restic snapshots --tag thunderbird-profile --json 2>/dev/null
    else
        RESTIC_REPOSITORY="${repo}" restic snapshots --tag thunderbird-profile --json 2>/dev/null
    fi
}

latest_snapshot_time() {
    python3 -c '
import json
import sys
from datetime import datetime

try:
    snapshots = json.load(sys.stdin)
except Exception:
    sys.exit(1)

latest = ""
for snapshot in snapshots:
    timestamp = snapshot.get("time") or ""
    if not timestamp:
        continue
    timestamp = timestamp.replace("Z", "+00:00")
    try:
        rendered = datetime.fromisoformat(timestamp).strftime("%Y-%m-%d %H:%M:%S")
    except ValueError:
        rendered = timestamp[:19].replace("T", " ")
    if rendered > latest:
        latest = rendered

if latest:
    print(latest)
'
}

format_lf_snapshots_as_activity() {
    python3 -c '
import json
import sys
from datetime import datetime

try:
    snapshots = json.load(sys.stdin)
except Exception:
    sys.exit(1)

for snapshot in snapshots:
    host = snapshot.get("hostname") or snapshot.get("host") or "unknown"
    timestamp = snapshot.get("time") or ""
    if not timestamp:
        continue
    timestamp = timestamp.replace("Z", "+00:00")
    try:
        dt = datetime.fromisoformat(timestamp)
        timestamp = dt.strftime("%Y-%m-%d %H:%M:%S")
    except ValueError:
        timestamp = timestamp[:19].replace("T", " ")
    print(f"{timestamp}\t{host}\tlocalfolders-backup")
'
}

# ── pCloud ────────────────────────────────────────────────────────────────────
if [[ -d "${pcloud_mount}" ]]; then
    pcloud_backup_root="${pcloud_mount}/${backup_root_rel}"
    pcloud_label="mounted (${pcloud_mount})"
elif [[ -d "${pcloud_drive}" ]]; then
    pcloud_backup_root="${pcloud_drive}/${backup_root_rel}"
    pcloud_label="mounted (${pcloud_drive})"
else
    pcloud_backup_root=""
    pcloud_label="not mounted"
fi

# ── Thunderbird ───────────────────────────────────────────────────────────────
if TB_FLATPAK_APP_ID=$(find_flatpak_thunderbird); then
    tb_type="Flatpak"
    tb_dir="${HOME}/.var/app/${TB_FLATPAK_APP_ID}/.thunderbird"
elif command -v snap &>/dev/null && run_quick_check snap list thunderbird; then
    tb_type="Snap"
    tb_dir="${HOME}/snap/thunderbird/common/.thunderbird"
elif command -v thunderbird &>/dev/null; then
    tb_type="System"
    tb_dir="${HOME}/.thunderbird"
else
    tb_type="not found"
    tb_dir=""
fi

tb_version="unknown"
if [[ "${tb_type}" == "Flatpak" ]]; then
    tb_version=$(timeout 5s flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null \
        | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
elif [[ "${tb_type}" != "not found" ]] && command -v thunderbird &>/dev/null; then
    tb_version=$(thunderbird --version 2>/dev/null | awk '{print $2}' || true)
fi
[[ -n "${tb_version}" ]] || tb_version="unknown"

if check_thunderbird_running; then
    tb_running="yes"
else
    tb_running="no"
fi

# ── Role ──────────────────────────────────────────────────────────────────────
if [[ -f "${NO_REVIEW_FILE}" ]]; then
    tb_role="non-review"
else
    tb_role="review"
fi

# ── Backup manifest ───────────────────────────────────────────────────────────
manifest_date=""
manifest_profile=""
manifest_files=""
manifest_profile_size=""
if [[ -n "${pcloud_backup_root}" && -f "${pcloud_backup_root}/thunderbird/.backup_manifest" ]]; then
    mf="${pcloud_backup_root}/thunderbird/.backup_manifest"
    manifest_date=$(awk -F= '/^date=/{print $2}' "${mf}")
    manifest_profile=$(awk -F= '/^profile=/{print $2}' "${mf}")
    manifest_files=$(awk -F= '/^file_count=/{print $2}' "${mf}")
    manifest_profile_size=$(awk -F= '/^profile_size=/{print $2}' "${mf}")
fi

# ── Sizes ─────────────────────────────────────────────────────────────────────
pcloud_backup_size=""
if [[ -n "${pcloud_backup_root}" && -d "${pcloud_backup_root}" ]]; then
    pcloud_backup_size=$(du -sh "${pcloud_backup_root}" 2>/dev/null | cut -f1 || true)
fi

if [[ -d "${local_staging}" ]]; then
    local_staging_size=$(du -sh "${local_staging}" 2>/dev/null | cut -f1 || true)
    local_staging_label="present (${local_staging_size})"
else
    local_staging_label="absent"
fi

# ── Last restore ──────────────────────────────────────────────────────────────
last_restore=""
[[ -f "${LAST_RESTORE_FILE}" ]] && last_restore=$(cat "${LAST_RESTORE_FILE}")

# ── Profile snapshot status ──────────────────────────────────────────────────
profile_snapshot_label="not configured"
profile_repo="${pcloud_backup_root:+${pcloud_backup_root}/${default_profile_repo_subdir}}"
profile_pw_file="${pcloud_backup_root:+${pcloud_backup_root}/.restic-password}"
if [[ -n "${profile_repo}" ]]; then
    if [[ ! -f "${profile_repo}/config" ]]; then
        profile_snapshot_label="repo missing"
    elif ! command -v restic >/dev/null 2>&1; then
        profile_snapshot_label="restic not installed"
    elif [[ -z "${RESTIC_PASSWORD:-}" && -z "${RESTIC_PASSWORD_FILE:-}" && ! -f "${profile_pw_file}" ]]; then
        profile_snapshot_label="password unavailable"
    else
        if profile_snapshot_latest=$(query_profile_snapshots_json "${profile_repo}" "${profile_pw_file}" | latest_snapshot_time); then
            if [[ -n "${profile_snapshot_latest}" ]]; then
                profile_snapshot_label="${profile_snapshot_latest} (restic)"
            else
                profile_snapshot_label="no snapshots"
            fi
        else
            profile_snapshot_label="snapshots unavailable"
        fi
    fi
fi

# ── This machine's last backup (from activity log) ────────────────────────────
this_host_last_backup=""
if [[ -n "${pcloud_backup_root}" && -f "${pcloud_backup_root}/activity.log" ]]; then
    this_host_last_backup=$(awk -F'\t' -v host="$(hostname -s)" '
        NF == 3 && $2 == host && $3 == "backup" {
            if ($1 > last) last = $1
        }
        END { if (last != "") print last }
    ' "${pcloud_backup_root}/activity.log")
fi

# ── Local Folders backup status ───────────────────────────────────────────────
lf_snapshot_activity=""
lf_backup_label="(none)"
lf_repo_status=""
lf_repo="${pcloud_backup_root:+${pcloud_backup_root}/${default_repo_subdir}}"
lf_pw_file="${pcloud_backup_root:+${pcloud_backup_root}/.restic-password}"

if [[ -n "${pcloud_backup_root}" && -f "${pcloud_backup_root}/activity.log" ]]; then
    lf_activity_latest=$(awk -F'\t' '
        NF == 3 && $3 == "localfolders-backup" {
            if ($1 > last) last = $1
        }
        END { if (last != "") print last }
    ' "${pcloud_backup_root}/activity.log")
else
    lf_activity_latest=""
fi

if [[ -n "${lf_repo}" ]]; then
    if [[ ! -f "${lf_repo}/config" ]]; then
        lf_repo_status="repo missing"
    elif ! command -v restic >/dev/null 2>&1; then
        lf_repo_status="restic not installed"
    elif [[ -z "${RESTIC_PASSWORD:-}" && -z "${RESTIC_PASSWORD_FILE:-}" && ! -f "${lf_pw_file}" ]]; then
        lf_repo_status="password unavailable"
    else
        lf_snapshot_activity=$(mktemp)
        trap '[[ -n "${lf_snapshot_activity}" ]] && rm -f "${lf_snapshot_activity}"' EXIT
        if query_lf_snapshots_json "${lf_repo}" "${lf_pw_file}" | format_lf_snapshots_as_activity > "${lf_snapshot_activity}"; then
            if [[ -s "${lf_snapshot_activity}" ]]; then
                lf_snapshot_latest=$(awk -F'\t' '{ if ($1 > last) last = $1 } END { if (last != "") print last }' "${lf_snapshot_activity}")
            else
                lf_snapshot_latest=""
                lf_repo_status="no snapshots"
            fi
        else
            : > "${lf_snapshot_activity}"
            lf_snapshot_latest=""
            lf_repo_status="snapshots unavailable"
        fi
    fi
fi

if [[ -n "${lf_activity_latest}" && -n "${lf_snapshot_latest:-}" ]]; then
    if [[ "${lf_activity_latest}" > "${lf_snapshot_latest}" ]]; then
        lf_backup_label="${lf_activity_latest} (activity log)"
    else
        lf_backup_label="${lf_snapshot_latest} (restic)"
    fi
elif [[ -n "${lf_activity_latest}" ]]; then
    lf_backup_label="${lf_activity_latest} (activity log)"
elif [[ -n "${lf_snapshot_latest:-}" ]]; then
    lf_backup_label="${lf_snapshot_latest} (restic)"
elif [[ -n "${lf_repo_status}" ]]; then
    lf_backup_label="${lf_repo_status}"
fi

# ── Restore status ────────────────────────────────────────────────────────────
if [[ -z "${pcloud_backup_root}" ]]; then
    restore_status="Unknown (pCloud not mounted)"
elif [[ -z "${manifest_date}" ]]; then
    restore_status="Unknown (no backup manifest)"
elif [[ -n "${this_host_last_backup}" && ! "${this_host_last_backup}" < "${manifest_date}" ]]; then
    restore_status="Up to date (this machine created the current backup)"
elif [[ -z "${last_restore}" ]]; then
    restore_status="Restore needed (never restored on this machine)"
elif [[ "${last_restore}" < "${manifest_date}" ]]; then
    restore_status="Restore needed (backup is newer than last restore)"
else
    restore_status="Up to date"
fi

# ── Report ────────────────────────────────────────────────────────────────────
cat <<EOF
==============================
  Thunderbird Status Report
==============================
  Date:               $(date '+%Y-%m-%d %H:%M:%S')
  Machine:            $(hostname -s)
  Thunderbird:        ${tb_type} ${tb_version}
  Running:            ${tb_running}
  Role:               ${tb_role}

  --- Backup ---
  Storage:            pCloud sync (${pcloud_label})
  Profile snapshot:   ${profile_snapshot_label}
  Current mirror:     ${manifest_date:-(none)}
  Profile:            ${manifest_profile:-(unknown)}
  Files:              ${manifest_files:-(unknown)}
  Profile size:       ${manifest_profile_size:-(unknown)}
  Last LF backup:     ${lf_backup_label}
  pCloud backup size: ${pcloud_backup_size:-(unavailable)}
  Local staging:      ${local_staging_label}

  --- This Machine ---
  Last restore:       ${last_restore:-(never)}
  Status:             ${restore_status}

  --- Computer Activity ---
EOF

if [[ -n "${pcloud_backup_root}" ]]; then
    format_activity_table "${pcloud_backup_root}/activity.log" "${lf_snapshot_activity}"
else
    printf '  (pCloud not mounted)\n'
fi

echo "=============================="
