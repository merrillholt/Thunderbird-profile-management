#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
MERGE_HELPER="${SCRIPT_DIR}/thunderbird-mbox-merge"

pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
default_profile_repo_subdir="profile-restic"
activity_fallback="${HOME}/.local/share/thunderbird-backup/activity.log.fallback"

dry_run=false
self_test=false
self_test_root=""
no_merge=false
check=false
list=false
snapshot_id=""
merge_work_dir=""
snapshot_restore_dir=""
merge_status="Skipped"

LAST_RESTORE_FILE="${HOME}/.config/tbblock/last-restore"

trap '[[ -n "${merge_work_dir:-}" ]] && rm -rf "${merge_work_dir}"; [[ -n "${snapshot_restore_dir:-}" ]] && rm -rf "${snapshot_restore_dir}"' EXIT

have_restic_password() {
    [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" || -f "${restic_password_file:-}" ]]
}

run_profile_restic() {
    local repo="$1"
    shift

    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic "$@"
    else
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic "$@"
    fi
}

log_activity() {
    local action="$1" status="$2" detail="$3" log_path="$4"
    local line
    line=$(printf '%s\t%s\t%s\t%s\t%s' "$(date '+%Y-%m-%d %H:%M:%S')" "$(hostname -s)" "${action}" "${status}" "${detail}")
    if [[ -n "${log_path}" ]] && printf '%s\n' "${line}" >> "${log_path}" 2>/dev/null; then
        return 0
    fi
    mkdir -p "$(dirname "${activity_fallback}")"
    printf '%s\n' "${line}" >> "${activity_fallback}"
    echo "Warning: could not write activity log to ${log_path:-(unset)}; appended to ${activity_fallback}" >&2
    return 0
}

format_activity_table() {
    local log_path="$1"
    if [[ ! -f "${log_path}" ]]; then
        printf '  (no activity recorded yet)\n'
        return
    fi
    printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "Computer" "Last Backup" "Last LF Backup" "Last Restore" "Status"
    printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "--------------------" "----------------------" "----------------------" "----------------------" "----------"
    awk -F'\t' '
        NF >= 3 {
            host=$2; action=$3; date=$1
            status=(NF >= 4 ? $4 : "ok")
            if (action=="backup"             && (!(host in b)  || date>b[host]))  { b[host]=date;  bs[host]=status }
            if (action=="localfolders-backup" && (!(host in lf) || date>lf[host])) { lf[host]=date; ls[host]=status }
            if (action=="restore"            && (!(host in r)  || date>r[host]))  { r[host]=date;  rs[host]=status }
            if (!(host in last) || date>last[host]) { last[host]=date; lasts[host]=status }
            seen[host]=1
        }
        END {
            for (host in seen)
                printf "%s\t%s\t%s\t%s\t%s\n", host,
                    (host in b ? b[host] : "-"),
                    (host in lf ? lf[host] : "-"),
                    (host in r ? r[host] : "-"),
                    (host in lasts ? lasts[host] : "-")
        }
    ' "${log_path}" | sort | while IFS=$'\t' read -r host bdate lfdate rdate status; do
        printf '  %-20s  %-22s  %-22s  %-22s  %-10s\n' "${host}" "${bdate}" "${lfdate}" "${rdate}" "${status}"
    done
}

get_this_host_last_backup() {
    local log_path="$1"
    [[ -f "${log_path}" ]] || return 0

    awk -F'\t' -v host="$(hostname -s)" '
        NF >= 3 && $2 == host && $3 == "backup" {
            if ($1 > last) last = $1
        }
        END { if (last != "") print last }
    ' "${log_path}"
}

# Query restic for the snapshot to restore and emit pipe-separated fields:
# short_id|iso_time|formatted_time
# If snapshot_arg is "latest", picks the most recent --tag thunderbird-profile snapshot.
query_snapshot_meta() {
    local repo="$1"
    local snapshot_arg="$2"
    local restic_args=(snapshots --tag thunderbird-profile --json)
    if [[ "${snapshot_arg}" == "latest" ]]; then
        restic_args+=(--latest 1)
    else
        restic_args+=("${snapshot_arg}")
    fi
    if [[ -n "${RESTIC_PASSWORD:-}" || -n "${RESTIC_PASSWORD_FILE:-}" ]]; then
        RESTIC_REPOSITORY="${repo}" restic "${restic_args[@]}" 2>/dev/null
    else
        RESTIC_REPOSITORY="${repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic "${restic_args[@]}" 2>/dev/null
    fi | python3 -c '
import json, sys
from datetime import datetime
try:
    snaps = json.load(sys.stdin)
except Exception:
    sys.exit(1)
if not snaps:
    sys.exit(2)
s = snaps[-1]
short_id = s.get("short_id") or (s.get("id") or "")[:8]
ts = s.get("time") or ""
formatted = ""
if ts:
    raw = ts.replace("Z", "+00:00")
    try:
        formatted = datetime.fromisoformat(raw).strftime("%Y-%m-%d %H:%M:%S")
    except ValueError:
        formatted = ts[:19].replace("T", " ")
print(f"{short_id}|{ts}|{formatted}")
'
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [--dry-run] [--no-merge] [--self-test] [--check] [--list] [--snapshot ID]

Options:
  --dry-run    Show what would be restored without making changes
  --no-merge   Replace local folders entirely (skip message-level merge)
  --self-test  Run a safe self-test against a temporary restic repository
  --check      Check if a restore is needed without restoring
               Exit 0 = up to date, 1 = restore needed, 2 = unknown
  --list       List available profile snapshots without restoring
  --snapshot ID
               Restore from a specific profile snapshot instead of the latest
  -h, --help   Show this help
EOF
}

i=0
args=("$@")
while (( i < ${#args[@]} )); do
    case "${args[$i]}" in
        --dry-run) dry_run=true ;;
        --no-merge) no_merge=true ;;
        --self-test) self_test=true ;;
        --check) check=true ;;
        --list) list=true ;;
        --snapshot)
            (( i++ )) || true
            snapshot_id="${args[$i]:-}"
            if [[ -z "${snapshot_id}" ]]; then
                echo "Error: --snapshot requires a snapshot ID." >&2
                exit 1
            fi
            ;;
        --snapshot=*) snapshot_id="${args[$i]#--snapshot=}" ;;
        -h|--help) usage; exit 0 ;;
        *)
            echo "Error: Unknown option: ${args[$i]}" >&2
            usage >&2
            exit 1
            ;;
    esac
    (( i++ )) || true
done

setup_self_test() {
    self_test_root=$(mktemp -d)
    trap 'rm -rf "${self_test_root}"; [[ -n "${merge_work_dir:-}" ]] && rm -rf "${merge_work_dir}"; [[ -n "${snapshot_restore_dir:-}" ]] && rm -rf "${snapshot_restore_dir}"' EXIT
    tb_type="SelfTest"
    tb_version="self-test"
    tb_dir="${self_test_root}/tb"
    pcloud_backup_root="${self_test_root}/backup/${backup_root_rel}"
    profile_restic_repo="${pcloud_backup_root}/${default_profile_repo_subdir}"
    restic_password_file="${pcloud_backup_root}/.restic-password"
    activity_log="${pcloud_backup_root}/activity.log"
    LAST_RESTORE_FILE="${self_test_root}/config/tbblock/last-restore"

    mkdir -p "${tb_dir}/restore.target" "${pcloud_backup_root}"

    # Build a "source" profile to back up.
    local src_profile="${self_test_root}/source/test.profile"
    mkdir -p "${src_profile}"
    echo 'user_pref("mail.server.server1.hostname", "example.com");' > "${src_profile}/prefs.js"

    # Build an aux dir with profile-root + metadata to back up alongside.
    local src_aux="${self_test_root}/source/aux"
    mkdir -p "${src_aux}/profile-root" "${src_aux}/metadata"
    cat <<EOF > "${self_test_root}/source/profiles.ini"
[Profile0]
Name=SelfTest
IsRelative=1
Path=test.profile
Default=1

[InstallSelfTest]
Default=test.profile
Locked=1
EOF
    cp "${self_test_root}/source/profiles.ini" "${src_aux}/profile-root/profiles.ini"
    {
        echo "date=$(date '+%Y-%m-%d %H:%M:%S')"
        echo "home=${self_test_root}"
        echo "thunderbird=${tb_type}"
        echo "thunderbird_version=${tb_version}"
        echo "profile=SelfTest"
        echo "profile_root=${self_test_root}/source"
        echo "profile_path=${src_profile}"
    } > "${src_aux}/metadata/restore-context.env"

    # Target profile registry (so profile-path detection works).
    cat <<EOF > "${tb_dir}/profiles.ini"
[Profile0]
Name=SelfTest
IsRelative=1
Path=restore.target
Default=1

[InstallSelfTest]
Default=restore.target
Locked=1
EOF

    printf 'self-test-password\n' > "${restic_password_file}"
    chmod 600 "${restic_password_file}"
    RESTIC_REPOSITORY="${profile_restic_repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" restic init >/dev/null
    RESTIC_REPOSITORY="${profile_restic_repo}" RESTIC_PASSWORD_FILE="${restic_password_file}" \
        restic backup --tag thunderbird --tag thunderbird-profile \
        --tag "tb-type:${tb_type}" --tag "tb-version:${tb_version}" \
        --host "$(hostname -s)" \
        "${src_profile}" "${src_aux}" >/dev/null
}

# Resolve pCloud location (or self-test scaffolding).
if "${self_test}"; then
    setup_self_test
else
    if [[ -d "${pcloud_mount}" ]]; then
        if [[ ! -r "${pcloud_mount}" ]]; then
            echo "Error: ${pcloud_mount} is not readable." >&2
            exit 1
        fi
        pcloud_backup_root="${pcloud_mount}/${backup_root_rel}"
    elif [[ -d "${pcloud_drive}" ]]; then
        pcloud_backup_root="${pcloud_drive}/${backup_root_rel}"
    else
        echo "Error: No Thunderbird backup found in pCloud" >&2
        exit 1
    fi
    profile_restic_repo="${pcloud_backup_root}/${default_profile_repo_subdir}"
    restic_password_file="${pcloud_backup_root}/.restic-password"
    activity_log="${pcloud_backup_root}/activity.log"
fi

if ! command -v restic >/dev/null 2>&1; then
    echo "Error: restic not found." >&2
    exit 1
fi
if [[ ! -f "${profile_restic_repo}/config" ]]; then
    echo "Error: Profile restic repository missing: ${profile_restic_repo}" >&2
    exit 1
fi
if ! have_restic_password; then
    echo "Error: Restic password unavailable." >&2
    echo "Set RESTIC_PASSWORD/RESTIC_PASSWORD_FILE or create: ${restic_password_file}" >&2
    exit 1
fi

# ── --list ───────────────────────────────────────────────────────────────────
if "${list}"; then
    last_restore=""
    [[ -f "${LAST_RESTORE_FILE}" ]] && last_restore=$(cat "${LAST_RESTORE_FILE}")
    cat <<EOF
==============================
  Restore Sources
==============================
  Repository:         ${profile_restic_repo}
  Last local restore: ${last_restore:-(never)}
  Use --snapshot ID to restore a specific snapshot below.
==============================

Profile Snapshot History
EOF
    run_profile_restic "${profile_restic_repo}" snapshots --tag thunderbird-profile --compact
    exit 0
fi

# Resolve target snapshot metadata.
snapshot_arg="${snapshot_id:-latest}"
set +e
snapshot_meta=$(query_snapshot_meta "${profile_restic_repo}" "${snapshot_arg}")
meta_status=$?
set -e
if [[ "${meta_status}" -ne 0 || -z "${snapshot_meta}" ]]; then
    echo "Error: No matching profile snapshot found in ${profile_restic_repo}" >&2
    [[ "${snapshot_arg}" != "latest" ]] && echo "       (looking for: ${snapshot_arg})" >&2
    exit 1
fi
snapshot_short_id="${snapshot_meta%%|*}"
remaining="${snapshot_meta#*|}"
snapshot_when="${remaining#*|}"

# ── --check ──────────────────────────────────────────────────────────────────
if "${check}"; then
    last_restore=""
    [[ -f "${LAST_RESTORE_FILE}" ]] && last_restore=$(cat "${LAST_RESTORE_FILE}")
    this_host_last_backup=$(get_this_host_last_backup "${activity_log}")

    printf 'Snapshot:      %s (%s)\n' "${snapshot_short_id}" "${snapshot_when}"
    printf 'Last restore:  %s\n' "${last_restore:-(never)}"
    echo "NOTE: verify pCloud has finished syncing on this machine before restoring."

    if [[ -z "${snapshot_when}" ]]; then
        echo "Status:        Unknown (no snapshot data)"
        exit 2
    elif [[ -n "${this_host_last_backup}" && ! "${this_host_last_backup}" < "${snapshot_when}" ]]; then
        echo "Status:        Up to date (this machine created the current snapshot)"
        exit 0
    elif [[ -z "${last_restore}" ]]; then
        echo "Status:        Restore needed (never restored on this machine)"
        exit 1
    elif [[ "${last_restore}" < "${snapshot_when}" ]]; then
        echo "Status:        Restore needed (snapshot is newer than last restore)"
        exit 1
    else
        echo "Status:        Up to date"
        exit 0
    fi
fi

# ── Thunderbird detection ────────────────────────────────────────────────────
run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 5s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

find_flatpak_thunderbird() {
    local app_id
    for app_id in org.mozilla.thunderbird_esr org.mozilla.thunderbird org.mozilla.Thunderbird; do
        if command -v flatpak &>/dev/null && run_quick_check flatpak info "${app_id}"; then
            printf '%s\n' "${app_id}"
            return 0
        fi
    done
    return 1
}

TB_FLATPAK_APP_ID=""
if ! "${self_test}"; then
    if TB_FLATPAK_APP_ID=$(find_flatpak_thunderbird); then
        tb_type="Flatpak"
        tb_dir="${HOME}/.var/app/${TB_FLATPAK_APP_ID}/.thunderbird"
    elif command -v snap &>/dev/null && run_quick_check snap list thunderbird; then
        tb_type="Snap"
        tb_dir="${HOME}/snap/thunderbird/common/.thunderbird"
    elif command -v thunderbird &>/dev/null; then
        tb_type="System"
        tb_dir="${HOME}/.thunderbird"
    else
        echo "Error: No Thunderbird installation found" >&2
        exit 1
    fi
fi

get_tb_version() {
    local detected_type="$1"
    local version="unknown"
    case "${detected_type}" in
        Flatpak)
            if command -v timeout >/dev/null 2>&1; then
                version=$(timeout 5s flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            else
                version=$(flatpak info "${TB_FLATPAK_APP_ID}" 2>/dev/null | awk -F': *' '/^[[:space:]]*Version:/{print $2}' || true)
            fi
            ;;
        *)
            if command -v thunderbird >/dev/null 2>&1; then
                version=$(thunderbird --version 2>/dev/null | awk '{print $2}' || true)
            fi
            ;;
    esac
    [[ -n "${version}" ]] || version="unknown"
    echo "${version}"
}

get_major_version() {
    local version="$1"
    echo "${version}" | grep -oE '[0-9]+' | head -n1
}

if ! "${self_test}"; then
    tb_version=$(get_tb_version "${tb_type}")
fi

profiles_ini="${tb_dir}/profiles.ini"
if [[ ! -f "${profiles_ini}" ]]; then
    echo "Error: ${profiles_ini} not found" >&2
    echo "Please launch Thunderbird once to create a default profile, then re-run this script." >&2
    exit 1
fi

profile_path=$(python3 "${SCRIPT_DIR}/thunderbird_profile.py" "${tb_dir}") || {
    echo "Error: Could not determine active Thunderbird profile from ${tb_dir}/profiles.ini" >&2
    exit 1
}
active_profile=$(basename "${profile_path}")

dest="${profile_path}/"

check_thunderbird_running() {
    pgrep -x thunderbird &>/dev/null || \
    pgrep -x thunderbird-bin &>/dev/null || \
    { command -v flatpak &>/dev/null && flatpak ps --columns=application 2>/dev/null | grep -Eq '^(org\.mozilla\.thunderbird_esr|org\.mozilla\.thunderbird|org\.mozilla\.Thunderbird)$'; }
}

reset_profile_runtime_state() {
    local profile_dir="$1"
    rm -f "${profile_dir}/compatibility.ini" 2>/dev/null || true
    rm -f "${profile_dir}/addonStartup.json.lz4" 2>/dev/null || true
    rm -rf "${profile_dir}/startupCache" 2>/dev/null || true
    if [[ "${tb_type}" == "Flatpak" ]]; then
        local profile_name
        profile_name=$(basename "${profile_dir}")
        rm -rf "${HOME}/.var/app/${TB_FLATPAK_APP_ID}/cache/thunderbird/${profile_name}/startupCache" 2>/dev/null || true
    fi
}

if ! "${self_test}" && ! "${dry_run}" && check_thunderbird_running; then
    echo "Thunderbird is running."
    read -rp "Kill Thunderbird before restoring? [y/N] " confirm_kill
    if [[ "${confirm_kill}" != [yY] ]]; then
        echo "Error: Please close Thunderbird before restoring." >&2
        log_activity "restore" "cancelled" "thunderbird-running" "${activity_log}"
        exit 1
    fi
    pkill -x thunderbird 2>/dev/null || true
    if [[ "${tb_type}" == "Flatpak" ]]; then
        flatpak kill "${TB_FLATPAK_APP_ID}" 2>/dev/null || true
    fi
    sleep 2
    if check_thunderbird_running; then
        echo "Error: Thunderbird is still running. Please close it manually and retry." >&2
        log_activity "restore" "error" "thunderbird-still-running" "${activity_log}"
        exit 1
    fi
fi

# Show restore plan and confirm.
_peek_last_restore=""
[[ -f "${LAST_RESTORE_FILE}" ]] && _peek_last_restore=$(cat "${LAST_RESTORE_FILE}")

if "${self_test}"; then
    thunderbird_preflight="not checked (self-test)"
elif check_thunderbird_running; then
    thunderbird_preflight="running"
else
    thunderbird_preflight="closed"
fi

if "${no_merge}"; then
    local_merge_preflight="skipped (--no-merge)"
elif "${dry_run}"; then
    local_merge_preflight="skipped (dry run)"
elif "${self_test}"; then
    local_merge_preflight="skipped (self-test)"
elif [[ ! -d "${dest%/}/Mail/Local Folders" ]]; then
    local_merge_preflight="skipped (no local folders in destination)"
elif [[ ! -f "${MERGE_HELPER}" ]]; then
    local_merge_preflight="skipped (merge helper missing)"
else
    local_merge_preflight="will preserve local-only messages before overwrite"
fi

if "${dry_run}" || "${self_test}"; then
    pcloud_sync_preflight="not required"
else
    pcloud_sync_preflight="requires confirmation below"
fi

echo "Restore Preflight"
echo "  Thunderbird:       ${tb_type}"
echo "  Version:           ${tb_version}"
echo "  Thunderbird state: ${thunderbird_preflight}"
echo "  Source snapshot:   ${snapshot_short_id} (${snapshot_when})"
echo "  Destination root:  ${tb_dir}"
echo "  Destination profile: ${active_profile}"
echo "  Destination path:  ${dest}"
echo "  Last restore:      ${_peek_last_restore:-(never)}"
echo "  Local merge:       ${local_merge_preflight}"
echo "  pCloud sync:       ${pcloud_sync_preflight}"
if "${dry_run}"; then
    echo "  Mode:              dry run; would extract snapshot and restore into a temporary destination"
else
    echo "  Mode:              restore; current destination profile will be overwritten"
fi
echo

if ! "${dry_run}" && ! "${self_test}"; then
    read -rp "Has pCloud finished syncing on this machine? [y/N] " confirm_sync
    if [[ "${confirm_sync}" != [yY] ]]; then
        echo "Restore cancelled."
        log_activity "restore" "cancelled" "pcloud-sync-not-confirmed" "${activity_log}"
        exit 0
    fi
    echo "pCloud sync: confirmed by user."

    read -rp "This will overwrite the current profile. Continue? [y/N] " confirm
    if [[ "${confirm}" != [yY] ]]; then
        echo "Restore cancelled."
        log_activity "restore" "cancelled" "user-declined" "${activity_log}"
        exit 0
    fi
fi

# ── Extract snapshot ─────────────────────────────────────────────────────────
if "${self_test}"; then
    extract_parent="${self_test_root}/extract"
else
    extract_parent="${HOME}/.cache/thunderbird-restore"
fi
mkdir -p "${extract_parent}"
snapshot_restore_dir=$(mktemp -d --tmpdir="${extract_parent}" snapshot.XXXXXXXXXX)
echo "Extracting snapshot ${snapshot_short_id} into ${snapshot_restore_dir}..."
set +e
run_profile_restic "${profile_restic_repo}" restore "${snapshot_short_id}" --target "${snapshot_restore_dir}" >/dev/null
restore_status=$?
set -e
if [[ "${restore_status}" -ne 0 ]]; then
    echo "Error: restic restore failed (exit ${restore_status})." >&2
    log_activity "restore" "error" "restic-exit-${restore_status}" "${activity_log}"
    exit "${restore_status}"
fi

# Locate profile body, aux profile-root, and aux metadata inside the extract.
src=$(find "${snapshot_restore_dir}" -type f -name prefs.js -printf '%h\n' | head -n1)
if [[ -z "${src}" ]]; then
    echo "Error: Restored snapshot does not contain a Thunderbird prefs.js file." >&2
    log_activity "restore" "error" "no-prefs-js" "${activity_log}"
    exit 1
fi
src="${src}/"

aux_root=$(find "${snapshot_restore_dir}" -type d -path '*/thunderbird-backup/aux' | head -n1)
metadata_src=""
if [[ -n "${aux_root}" ]]; then
    [[ -d "${aux_root}/metadata" ]]     && metadata_src="${aux_root}/metadata"
fi

# Version-mismatch check from the embedded restore-context.env.
if [[ -n "${metadata_src}" && -f "${metadata_src}/restore-context.env" ]]; then
    snapshot_tb_type=$(awk -F= '/^thunderbird=/{print $2}' "${metadata_src}/restore-context.env")
    snapshot_tb_version=$(awk -F= '/^thunderbird_version=/{print $2}' "${metadata_src}/restore-context.env")
    snapshot_profile=$(awk -F= '/^profile=/{print $2}' "${metadata_src}/restore-context.env")
    if [[ -n "${snapshot_tb_type}" && "${snapshot_tb_type}" != "${tb_type}" ]]; then
        echo "Warning: Snapshot was created from ${snapshot_tb_type}, restore target is ${tb_type}."
    fi
    if [[ -n "${snapshot_tb_version}" && "${snapshot_tb_version}" != "unknown" && "${tb_version}" != "unknown" && "${snapshot_tb_version}" != "${tb_version}" ]]; then
        echo "Warning: Snapshot Thunderbird version (${snapshot_tb_version}) differs from target (${tb_version})."
        backup_major=$(get_major_version "${snapshot_tb_version}")
        target_major=$(get_major_version "${tb_version}")
        if [[ -n "${backup_major}" && -n "${target_major}" && "${target_major}" -lt "${backup_major}" ]]; then
            echo "Warning: Target appears older than snapshot source. This can cause startup/profile errors."
        fi
        if ! "${dry_run}" && ! "${self_test}"; then
            read -rp "Continue with version mismatch? [y/N] " confirm_version_mismatch
            if [[ "${confirm_version_mismatch}" != [yY] ]]; then
                echo "Restore cancelled."
                log_activity "restore" "cancelled" "version-mismatch" "${activity_log}"
                exit 0
            fi
        fi
    fi
    if [[ -n "${snapshot_profile}" && -n "${active_profile}" && "${snapshot_profile}" != "${active_profile}" ]]; then
        echo "Note: Snapshot profile name (${snapshot_profile}) differs from target active profile (${active_profile})."
        echo "      This restore will copy profile contents into the target active profile."
    fi
fi

resolved_dest=$(readlink -f "${dest}")
resolved_tb_dir=$(readlink -f "${tb_dir}")
if [[ "${resolved_dest}" != "${resolved_tb_dir}"/* ]]; then
    echo "Error: Refusing to restore outside Thunderbird profile directory: ${dest}" >&2
    log_activity "restore" "error" "dest-outside-profile" "${activity_log}"
    exit 1
fi

# ── Install native messaging host (Flatpak only) ─────────────────────────────
if ! "${dry_run}" && ! "${self_test}" && [[ "${tb_type}" == "Flatpak" ]]; then
    echo "Installing native messaging host..."
    "${SCRIPT_DIR}/install-native-host" 2>&1 || true
    echo
fi

# ── Local folder merge: snapshot pre-restore messages ────────────────────────
if ! "${no_merge}" && ! "${dry_run}" && ! "${self_test}"; then
    src_local="${src%/}/Mail/Local Folders"
    dest_local="${dest%/}/Mail/Local Folders"
    if [[ -d "${dest_local}" ]] && [[ -f "${MERGE_HELPER}" ]]; then
        merge_work_dir=$(mktemp -d)
        echo "Preserving local folder messages not in backup..."
        if ! python3 "${MERGE_HELPER}" snapshot "${src_local}" "${dest_local}" "${merge_work_dir}"; then
            echo "Error: Could not preserve local-only messages. Restore aborted before overwrite." >&2
            log_activity "restore" "error" "local-merge-snapshot-failed" "${activity_log}"
            exit 1
        fi
        echo
    else
        merge_status="Nothing to preserve (no local folders)"
    fi
elif "${no_merge}"; then
    merge_status="Skipped (--no-merge)"
fi

# ── rsync extracted profile into active profile ──────────────────────────────
echo
start_time=$(date +%s)
tmp_dry_dest=""
rsync_dest="${dest}"
if "${dry_run}"; then
    tmp_dry_dest=$(mktemp -d)
    rsync_dest="${tmp_dry_dest}/"
else
    mkdir -p "${dest}"
fi

rsync_common=(rsync -a --copy-links --exclude='lock' --exclude='.parentlock' --delete --stats)
if "${dry_run}"; then
    rsync_output=$("${rsync_common[@]}" --dry-run "${src}" "${rsync_dest}" 2>&1)
else
    rsync_output=$("${rsync_common[@]}" "${src}" "${dest}" 2>&1)

    # ── Local folder merge: re-add preserved messages ──────────────────────
    if [[ -n "${merge_work_dir}" ]]; then
        dest_local="${dest%/}/Mail/Local Folders"
        echo "Merging preserved messages..."
        if python3 "${MERGE_HELPER}" merge "${dest_local}" "${merge_work_dir}"; then
            merge_status="Complete"
        else
            merge_status="Failed (see output above)"
            echo "Error: Preserved local messages could not be merged." >&2
            log_activity "restore" "error" "local-merge-failed" "${activity_log}"
            exit 1
        fi
        rm -rf "${merge_work_dir}"
        merge_work_dir=""
        echo
    fi

    reset_profile_runtime_state "${dest%/}"

    mkdir -p "$(dirname "${LAST_RESTORE_FILE}")"
    printf '%s\n' "${snapshot_when}" > "${LAST_RESTORE_FILE}"
    if ! "${self_test}"; then
        log_activity "restore" "ok" "${snapshot_when}" "${activity_log}"
    fi
fi
[[ -n "${tmp_dry_dest}" ]] && rm -rf "${tmp_dry_dest}"
end_time=$(date +%s)
elapsed=$(( end_time - start_time ))

if (( elapsed >= 3600 )); then
    duration="$(( elapsed / 3600 ))h $(( (elapsed % 3600) / 60 ))m $(( elapsed % 60 ))s"
elif (( elapsed >= 60 )); then
    duration="$(( elapsed / 60 ))m $(( elapsed % 60 ))s"
else
    duration="${elapsed}s"
fi

files_transferred=$(echo "${rsync_output}" | awk '/Number of regular files transferred:/{print $NF}')
sent=$(echo "${rsync_output}" | awk '/Total bytes sent:/{if ($5!="") print $4" "$5; else print $4}')
profile_size=$(du -sh "${src}" 2>/dev/null | cut -f1 || echo "?")
if "${dry_run}"; then
    restored_size="n/a"
    file_count="n/a"
else
    restored_size=$(du -sh "${dest}" 2>/dev/null | cut -f1 || echo "?")
    file_count=$(find "${dest}" -type f 2>/dev/null | wc -l)
fi

# ── Apply MIME defaults ──────────────────────────────────────────────────────
mime_status=""
if ! "${dry_run}" && ! "${self_test}" && [[ -n "${metadata_src}" && -f "${metadata_src}/xdg-mime-defaults.txt" ]] && command -v xdg-mime &>/dev/null; then
    mime_applied=0
    mime_failed=0
    while IFS='=' read -r mime_type desktop_file; do
        [[ -z "${mime_type}" || -z "${desktop_file}" ]] && continue
        if xdg-mime default "${desktop_file}" "${mime_type}" 2>/dev/null; then
            (( mime_applied++ )) || true
        else
            (( mime_failed++ )) || true
        fi
    done < "${metadata_src}/xdg-mime-defaults.txt"
    if (( mime_applied > 0 && mime_failed == 0 )); then
        mime_status="Applied (${mime_applied} types)"
    elif (( mime_applied > 0 )); then
        mime_status="Partial (${mime_applied} applied, ${mime_failed} failed)"
    else
        mime_status="Failed"
    fi
else
    mime_status="Skipped"
fi

# ── Apply Flatpak sandbox restrictions ───────────────────────────────────────
flatpak_status=""
if ! "${dry_run}" && ! "${self_test}" && [[ "${tb_type}" == "Flatpak" ]] && [[ -n "${metadata_src}" && -f "${metadata_src}/flatpak-override-user.txt" ]]; then
    restrictions=$(grep -oP '(?<=filesystems=)[^;]+(?:;[^;]+)*' "${metadata_src}/flatpak-override-user.txt" 2>/dev/null \
        | tr ';' '\n' | grep -v '^/' | grep -v '^$' || true)
    if [[ -n "${restrictions}" ]]; then
        while IFS= read -r entry; do
            flatpak override --user "${TB_FLATPAK_APP_ID}" --filesystem="${entry}" 2>/dev/null || true
        done <<< "${restrictions}"
        flatpak_status="Applied: ${restrictions//$'\n'/, }"
    else
        flatpak_status="Nothing to apply"
    fi
elif ! "${dry_run}" && ! "${self_test}" && [[ "${tb_type}" == "Flatpak" ]]; then
    flatpak_status="Backup metadata not found"
else
    flatpak_status="Skipped"
fi

# ── Restore native messaging hosts ───────────────────────────────────────────
nm_host_status=""
if [[ -n "${metadata_src}" ]]; then
    nm_host_src="${metadata_src}/native-messaging-hosts"
else
    nm_host_src=""
fi
if ! "${dry_run}" && ! "${self_test}" && [[ -n "${nm_host_src}" && -d "${nm_host_src}" ]]; then
    if [[ "${tb_type}" == "Flatpak" ]]; then
        nm_host_dest="${HOME}/.mozilla/native-messaging-hosts"
        mkdir -p "${nm_host_dest}"
        cp -a "${nm_host_src}/." "${nm_host_dest}/"
        nm_count=$(find "${nm_host_src}" -maxdepth 1 -name "*.json" | wc -l)
        nm_host_status="Restored ${nm_count} manifest(s) to ${nm_host_dest}"
        flatpak override --user "${TB_FLATPAK_APP_ID}" \
            --filesystem="${nm_host_dest}:ro" 2>/dev/null || true
        while IFS= read -r manifest_path; do
            host_script=$(python3 -c "
import json,sys
try:
    print(json.load(open(sys.argv[1])).get('path',''))
except Exception:
    pass
" "${manifest_path}" 2>/dev/null || true)
            host_dir=$(dirname "${host_script}" 2>/dev/null || true)
            if [[ -n "${host_script}" && -d "${host_dir}" ]]; then
                flatpak override --user "${TB_FLATPAK_APP_ID}" \
                    --filesystem="${host_dir}" 2>/dev/null || true
                nm_host_status="${nm_host_status}; override applied for ${host_dir}"
            fi
        done < <(find "${nm_host_src}" -maxdepth 1 -name "*.json")
    else
        nm_host_status="Skipped (not Flatpak)"
    fi
else
    nm_host_status="Skipped"
fi

post_restore_notes=""
if ! "${dry_run}" && ! "${self_test}"; then
    post_restore_notes=$(cat <<'NOTES'

  Next steps (manual):
  1. Start Thunderbird and verify all accounts connect.
  2. Re-enter account passwords if prompted (system keyring is not
     included in the profile backup).
NOTES
)
fi

cat <<EOF

==============================
  Restore Report
==============================
  Date:               $(date '+%Y-%m-%d %H:%M:%S')
  Thunderbird:        ${tb_type}
  Version:            ${tb_version}
  Profile:            ${active_profile}
  Snapshot:           ${snapshot_short_id} (${snapshot_when})
  Destination:        ${dest}
  Duration:           ${duration}
  Files transferred:  ${files_transferred}
  Data transferred:   ${sent}
  Total files:        ${file_count}
  Restored size:      ${restored_size}
  Snapshot size:      ${profile_size}
  Local folder merge: ${merge_status}
  MIME defaults:      ${mime_status}
  Flatpak sandbox:    ${flatpak_status}
  Native msg hosts:   ${nm_host_status}
==============================
  Restore $("${dry_run}" && echo "(dry run) ")complete.
==============================
EOF

if ! "${dry_run}" && ! "${self_test}"; then
    echo
    echo "  Computer Activity"
    format_activity_table "${activity_log}"
fi
if [[ -n "${post_restore_notes}" ]]; then
    echo "${post_restore_notes}"
fi

if ! "${dry_run}" && ! "${self_test}"; then
    echo
    echo "=============================="
    echo "  Post-restore automation"
    echo "=============================="
    echo
    echo "--- tbblock-rebuild ---"
    "${SCRIPT_DIR}/tbblock-rebuild" --yes || true
    echo
    if [[ "${tb_type}" == "Flatpak" ]]; then
        echo "--- Flatpak sandbox permissions ---"
        flatpak override --user --show "${TB_FLATPAK_APP_ID}" 2>/dev/null || true
    fi
    echo "=============================="
fi

exit 0
