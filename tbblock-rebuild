#!/usr/bin/env python3
"""Apply queued domain block changes to Thunderbird filter files.

Usage:
  tbblock-rebuild           preview changes, prompt, and apply
  tbblock-rebuild --list    list domains in the current [TBQ] Blocked domains filter
"""

from __future__ import annotations

import configparser
import re
import subprocess
import sys
from pathlib import Path

DOMAINS_FILE = Path(__file__).resolve().parent / "blocked_domains.txt"
FLATPAK_TB_DIR = Path.home() / ".var/app/org.mozilla.Thunderbird/.thunderbird"
FILTER_NAME = "[TBQ] Blocked domains -> Trash"
INSERT_AFTER = "[TBQ] Trash senders -> Trash"
FALLBACK_BEFORE = "[TBQ] Spoofed trusted domains -> Spoofed"
ROUTE_FILTER_PREFIX = "[TBQ] Route -> "
ROUTE_INSERT_BEFORE = "[TBQ] Trash senders -> Trash"


def find_profile() -> Path:
    ini = FLATPAK_TB_DIR / "profiles.ini"
    if ini.exists():
        cp = configparser.ConfigParser()
        cp.read(ini)

        def resolve(rel: str, is_relative: bool) -> Path:
            return FLATPAK_TB_DIR / rel if is_relative else Path(rel)

        # [Install*] sections reflect the per-install active profile; check these first.
        for section in cp.sections():
            if section.startswith("Install"):
                rel = cp.get(section, "default", fallback="")
                if rel:
                    return resolve(rel, is_relative=True)

        # Fall back to the profile with Default=1.
        for section in cp.sections():
            if cp.get(section, "default", fallback="") == "1":
                rel = cp.get(section, "path", fallback="")
                if rel:
                    is_relative = cp.get(section, "isrelative", fallback="1") == "1"
                    return resolve(rel, is_relative)

    candidates = sorted(FLATPAK_TB_DIR.glob("*.default*"))
    if candidates:
        return candidates[0]
    raise RuntimeError(f"No Thunderbird profile found in {FLATPAK_TB_DIR}")


def is_tb_running() -> bool:
    for pattern in ("org.mozilla.Thunderbird", "thunderbird-bin", "thunderbird"):
        try:
            r = subprocess.run(["pgrep", "-f", pattern], capture_output=True)
            if r.returncode == 0:
                return True
        except FileNotFoundError:
            pass
    return False


def normalize(d: str) -> str:
    return "@" + d.strip().lstrip("@").lower()


def read_queue() -> tuple[dict[str, str], dict[str, str | None]]:
    """Parse blocked_domains.txt.

    Returns:
        blocks: {domain: "add" | "delete"}   — last action wins per domain
        routes: {domain: folder_name | None} — None means unroute; last action wins
    """
    if not DOMAINS_FILE.exists():
        return {}, {}
    blocks: dict[str, str] = {}
    routes: dict[str, str | None] = {}
    for line in DOMAINS_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(None, 2)
        action = parts[0] if parts else ""
        if action in ("add", "delete") and len(parts) == 2:
            blocks[normalize(parts[1])] = action
        elif action == "route" and len(parts) == 3:
            routes[normalize(parts[1])] = parts[2]
        elif action == "unroute" and len(parts) == 2:
            routes[normalize(parts[1])] = None
    return blocks, routes


def clear_queue() -> None:
    DOMAINS_FILE.write_text(
        "# Pending domain block changes. Managed by tbblock.\n"
        "# Run tbblock-rebuild to apply. File is cleared after apply.\n"
    )


def parse_blocks(content: str) -> tuple[str, list[str]]:
    lines = content.splitlines(keepends=True)
    header_lines: list[str] = []
    body_start = len(lines)
    for i, line in enumerate(lines):
        if line.startswith("name="):
            body_start = i
            break
        header_lines.append(line)
    header = "".join(header_lines)
    body = "".join(lines[body_start:])
    raw = re.split(r"(?=^name=)", body, flags=re.MULTILINE)
    return header, [b for b in raw if b.strip()]


def block_name(block: str) -> str:
    m = re.match(r'^name="([^"]*)"', block)
    return m.group(1) if m else ""


def extract_domains(block: str) -> list[str]:
    m = re.search(r'^condition="(.+)"', block, re.MULTILINE)
    if not m:
        return []
    return sorted(re.findall(r'\(from,contains,([^)]+)\)', m.group(1)))


def build_condition(domains: list[str]) -> str:
    return "OR " + " OR ".join(f"(from,contains,{d})" for d in domains)


def make_filter_block(condition: str) -> str:
    return (
        f'name="{FILTER_NAME}"\n'
        f'enabled="yes"\n'
        f'type="17"\n'
        f'action="AddTag"\n'
        f'actionValue="trash"\n'
        f'action="AddTag"\n'
        f'actionValue="tbq_identified"\n'
        f'action="Stop execution"\n'
        f'condition="{condition}"\n'
    )


def get_filter_domains(path: Path) -> set[str]:
    _, blocks = parse_blocks(path.read_text())
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)
    return set(extract_domains(blocks[idx])) if idx is not None else set()


def find_local_folder_uri(profile: Path, folder_name: str) -> str | None:
    mbox = profile / "Mail" / "Local Folders" / folder_name
    return f"mailbox://{mbox}" if mbox.exists() else None


def make_route_filter_block(folder_name: str, folder_uri: str, condition: str) -> str:
    name = f"{ROUTE_FILTER_PREFIX}{folder_name}"
    return (
        f'name="{name}"\n'
        f'enabled="yes"\n'
        f'type="17"\n'
        f'action="Copy to folder"\n'
        f'actionValue="{folder_uri}"\n'
        f'condition="{condition}"\n'
    )


def get_all_route_domains(path: Path) -> dict[str, set[str]]:
    """Return {folder_name: {domain, …}} from all [TBQ] Route -> * filters."""
    _, blocks = parse_blocks(path.read_text())
    result: dict[str, set[str]] = {}
    for b in blocks:
        name = block_name(b)
        if name.startswith(ROUTE_FILTER_PREFIX):
            folder = name[len(ROUTE_FILTER_PREFIX):]
            result.setdefault(folder, set()).update(extract_domains(b))
    return result


def get_all_route_domains_flat(path: Path) -> dict[str, str]:
    """Return {domain: folder_name} from all route filters in one file."""
    flat: dict[str, str] = {}
    for folder, domains in get_all_route_domains(path).items():
        for d in domains:
            flat[d] = folder
    return flat


def write_route_filters(path: Path, routes: dict[str, set[str]], profile: Path) -> None:
    """Write (or remove) all [TBQ] Route -> * filters.

    routes: {folder_name: {domain, …}} — complete desired state.
    """
    content = path.read_text()
    header, blocks = parse_blocks(content)

    # Remove all existing route filters.
    blocks = [b for b in blocks if not block_name(b).startswith(ROUTE_FILTER_PREFIX)]

    # Build new route filter blocks in sorted folder order.
    new_route_blocks: list[str] = []
    for folder_name in sorted(routes):
        domains = routes[folder_name]
        if not domains:
            continue
        uri = find_local_folder_uri(profile, folder_name)
        if uri is None:
            print(f"  Warning: local folder not found: {folder_name!r} — skipping", file=sys.stderr)
            continue
        new_route_blocks.append(
            make_route_filter_block(folder_name, uri, build_condition(sorted(domains)))
        )

    if new_route_blocks:
        anchor = next(
            (i for i, b in enumerate(blocks) if block_name(b) == ROUTE_INSERT_BEFORE),
            0,
        )
        for j, nb in enumerate(new_route_blocks):
            blocks.insert(anchor + j, nb)

    path.write_text(header + "".join(blocks))


def write_filter(path: Path, domains: set[str]) -> None:
    content = path.read_text()
    header, blocks = parse_blocks(content)
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)

    if not domains:
        if idx is not None:
            blocks = [b for b in blocks if block_name(b) != FILTER_NAME]
        path.write_text(header + "".join(blocks))
        return

    new_block = make_filter_block(build_condition(sorted(domains)))
    if idx is not None:
        blocks[idx] = new_block
    else:
        anchor = next((i for i, b in enumerate(blocks) if block_name(b) == INSERT_AFTER), None)
        if anchor is not None:
            blocks.insert(anchor + 1, new_block)
        else:
            fb = next((i for i, b in enumerate(blocks) if block_name(b) == FALLBACK_BEFORE), None)
            blocks.insert(fb if fb is not None else len(blocks), new_block)
    path.write_text(header + "".join(blocks))


def dn(n: int) -> str:
    return f"{n} domain{'s' if n != 1 else ''}"


def cmd_list() -> int:
    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    print(f'Current "{FILTER_NAME}" filter:')
    for path in filter_files:
        account = path.parent.name
        domains = sorted(get_filter_domains(path))
        if domains:
            print(f"  {account} ({dn(len(domains))}):")
            for d in domains:
                print(f"    {d}")
        else:
            print(f"  {account}: (no filter)")

    print()
    print(f'Current "{ROUTE_FILTER_PREFIX}*" filters:')
    for path in filter_files:
        account = path.parent.name
        routes = get_all_route_domains(path)
        if routes:
            total = sum(len(v) for v in routes.values())
            print(f"  {account} ({dn(total)}):")
            for folder_name in sorted(routes):
                for d in sorted(routes[folder_name]):
                    print(f"    {d} -> {folder_name}")
        else:
            print(f"  {account}: (no routes)")
    return 0


def cmd_apply() -> int:
    print(f"Command file: {DOMAINS_FILE}")

    block_queue, route_queue = read_queue()
    if not block_queue and not route_queue:
        print("  (empty — no pending changes)")
        return 0

    net_adds = {d for d, a in block_queue.items() if a == "add"}
    net_deletes = {d for d, a in block_queue.items() if a == "delete"}
    net_routes = {d: f for d, f in route_queue.items() if f is not None}
    net_unroutes = {d for d, f in route_queue.items() if f is None}

    n_add, n_del = len(net_adds), len(net_deletes)
    n_route, n_unroute = len(net_routes), len(net_unroutes)
    print(f"  Pending: {n_add} block add{'s' if n_add != 1 else ''}, "
          f"{n_del} block delete{'s' if n_del != 1 else ''}, "
          f"{n_route} route{'s' if n_route != 1 else ''}, "
          f"{n_unroute} unroute{'s' if n_unroute != 1 else ''}")
    print()

    if is_tb_running():
        print("ERROR: Thunderbird is running — quit it before applying changes.", file=sys.stderr)
        return 1

    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    # ── Block domain plan ────────────────────────────────────────────────────
    all_current: set[str] = set()
    for path in filter_files:
        all_current |= get_filter_domains(path)

    to_add = sorted(net_adds - all_current)
    to_delete = sorted(net_deletes & all_current)
    no_change = sorted(all_current - net_deletes)
    not_found_blocks = sorted(net_deletes - all_current)
    final_block_set = (all_current | net_adds) - net_deletes

    print(f"Block — No change ({len(no_change)}):")
    for d in no_change:
        print(f"  {d}")
    if not no_change:
        print("  (none)")

    print(f"Block — Add ({len(to_add)}):")
    for d in to_add:
        print(f"  + {d}")
    if not to_add:
        print("  (none)")

    total_del = len(to_delete) + len(not_found_blocks)
    print(f"Block — Delete ({total_del}):")
    for d in to_delete:
        print(f"  - {d}")
    for d in not_found_blocks:
        print(f"  ? {d}  (not in filter — no action)")
    if not to_delete and not not_found_blocks:
        print("  (none)")

    # ── Route plan ───────────────────────────────────────────────────────────
    all_current_routes: dict[str, str] = {}
    for path in filter_files:
        all_current_routes.update(get_all_route_domains_flat(path))

    routes_to_set = {d: f for d, f in net_routes.items()
                     if all_current_routes.get(d) != f}
    routes_to_delete = sorted(d for d in net_unroutes if d in all_current_routes)
    routes_not_found = sorted(d for d in net_unroutes if d not in all_current_routes)

    final_routes_flat: dict[str, str] = {**all_current_routes, **net_routes}
    for d in net_unroutes:
        final_routes_flat.pop(d, None)
    final_routes: dict[str, set[str]] = {}
    for domain, folder in final_routes_flat.items():
        final_routes.setdefault(folder, set()).add(domain)

    print()
    print(f"Route — Add/Update ({len(routes_to_set)}):")
    for d, f in sorted(routes_to_set.items()):
        print(f"  + {d} -> {f}")
    if not routes_to_set:
        print("  (none)")

    total_unroute = len(routes_to_delete) + len(routes_not_found)
    print(f"Route — Remove ({total_unroute}):")
    for d in routes_to_delete:
        print(f"  - {d}  (was -> {all_current_routes[d]})")
    for d in routes_not_found:
        print(f"  ? {d}  (not routed — no action)")
    if not routes_to_delete and not routes_not_found:
        print("  (none)")

    any_change = bool(to_add or to_delete or routes_to_set or routes_to_delete)
    print()

    if not any_change:
        print("No filter changes needed.")
        clear_queue()
        return 0

    try:
        answer = input("Apply these changes? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        return 1

    if answer not in ("y", "yes"):
        print("Aborted.")
        return 1

    print()
    for path in filter_files:
        write_filter(path, final_block_set)
        write_route_filters(path, final_routes, profile)
        account = path.parent.name
        parts = []
        if to_add:
            parts.append(f"+{len(to_add)} block")
        if to_delete:
            parts.append(f"-{len(to_delete)} block")
        if routes_to_set:
            parts.append(f"+{len(routes_to_set)} route")
        if routes_to_delete:
            parts.append(f"-{len(routes_to_delete)} route")
        print(f"  {account}: updated ({', '.join(parts)}, "
              f"{dn(len(final_block_set))} blocks, "
              f"{dn(len(final_routes_flat))} routes total)")

    clear_queue()
    print()
    print("Done. Start Thunderbird to load the updated filters.")
    return 0


def main() -> int:
    args = sys.argv[1:]
    if not args:
        return cmd_apply()
    if args[0] in ("--list", "-l"):
        return cmd_list()
    if args[0] in ("--help", "-h"):
        print(__doc__.strip())
        return 0
    print(f"Unknown option: {args[0]}", file=sys.stderr)
    print(__doc__.strip())
    return 1


if __name__ == "__main__":
    sys.exit(main())
