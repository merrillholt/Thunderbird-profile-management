#!/usr/bin/env python3
"""Apply queued domain block changes to Thunderbird filter files.

Usage:
  tbblock-rebuild             preview changes, prompt, and apply
  tbblock-rebuild --dry-run   preview changes without applying
  tbblock-rebuild --no-review force no-review mode for this run
  tbblock-rebuild --list      show current filter and role state

Role (review vs no-review) is determined by the marker file:
  ~/.config/tbblock/no-review

If the marker exists this machine is treated as a non-review system and
the catch-all filter is disabled. Remove it to restore review mode.
The --no-review flag overrides the marker for a single run.
"""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

from thunderbird_profile import find_default_profile

DOMAINS_FILE = Path(__file__).resolve().parent / "blocked_domains.txt"
QUEUE_HEADER = (
    "# Pending domain block changes. Managed by tbblock.\n"
    "# Run tbblock-rebuild to apply. File is cleared after apply.\n"
)
FILTER_NAME = "[TBQ] Blocked domains -> Trash"
INSERT_AFTER = "[TBQ] Trash senders -> Trash"
FALLBACK_BEFORE = "[TBQ] Spoofed trusted domains -> Spoofed"
ROUTE_FILTER_PREFIX = "[TBQ] Route -> "
ROUTE_INSERT_BEFORE = "[TBQ] Trash senders -> Trash"
CATCHALL_FILTER_NAME = "[TBQ] Catch-all quarantine -> Review"
NO_REVIEW_MARKER = Path.home() / ".config/tbblock/no-review"


def find_profile() -> Path:
    return find_default_profile()


def is_tb_running() -> bool:
    for process_name in ("thunderbird-bin", "thunderbird"):
        try:
            r = subprocess.run(["pgrep", "-x", process_name], capture_output=True)
            if r.returncode == 0:
                return True
        except FileNotFoundError:
            pass

    try:
        r = subprocess.run(
            ["flatpak", "ps", "--columns=application"],
            capture_output=True,
            text=True,
        )
        if r.returncode == 0 and "org.mozilla.Thunderbird" in r.stdout.splitlines():
            return True
    except FileNotFoundError:
        pass

    return False


def normalize(d: str) -> str:
    return "@" + d.strip().lstrip("@").lower()


def read_queue() -> tuple[dict[str, str], dict[str, str | None]]:
    """Parse blocked_domains.txt.

    Returns:
        blocks: {domain: "add" | "delete"}   — last action wins per domain
        routes: {domain: folder_ref | None}  — None means unroute; last action wins
    """
    if not DOMAINS_FILE.exists():
        return {}, {}
    blocks: dict[str, str] = {}
    routes: dict[str, str | None] = {}
    for line in DOMAINS_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(None, 2)
        action = parts[0] if parts else ""
        if action in ("add", "delete") and len(parts) == 2:
            blocks[normalize(parts[1])] = action
        elif action == "route" and len(parts) == 3:
            routes[normalize(parts[1])] = parts[2]
        elif action == "unroute" and len(parts) == 2:
            routes[normalize(parts[1])] = None
    return blocks, routes


def clear_queue() -> None:
    DOMAINS_FILE.write_text(QUEUE_HEADER)


def write_remaining_queue(routes: dict[str, str]) -> None:
    lines = [QUEUE_HEADER]
    for domain, folder in sorted(routes.items()):
        lines.append(f"route {domain} {folder}\n")
    DOMAINS_FILE.write_text("".join(lines))


def parse_blocks(content: str) -> tuple[str, list[str]]:
    lines = content.splitlines(keepends=True)
    header_lines: list[str] = []
    body_start = len(lines)
    for i, line in enumerate(lines):
        if line.startswith("name="):
            body_start = i
            break
        header_lines.append(line)
    header = "".join(header_lines)
    body = "".join(lines[body_start:])
    raw = re.split(r"(?=^name=)", body, flags=re.MULTILINE)
    return header, [b for b in raw if b.strip()]


def block_name(block: str) -> str:
    m = re.match(r'^name="([^"]*)"', block)
    return m.group(1) if m else ""


def extract_domains(block: str) -> list[str]:
    m = re.search(r'^condition="(.+)"', block, re.MULTILINE)
    if not m:
        return []
    return sorted(re.findall(r'\(from,contains,([^)]+)\)', m.group(1)))


def build_condition(domains: list[str]) -> str:
    return "OR " + " OR ".join(f"(from,contains,{d})" for d in domains)


def make_filter_block(condition: str) -> str:
    return (
        f'name="{FILTER_NAME}"\n'
        f'enabled="yes"\n'
        f'type="17"\n'
        f'action="AddTag"\n'
        f'actionValue="trash"\n'
        f'action="AddTag"\n'
        f'actionValue="tbq_identified"\n'
        f'action="Stop execution"\n'
        f'condition="{condition}"\n'
    )


def get_filter_domains(path: Path) -> set[str]:
    _, blocks = parse_blocks(path.read_text())
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)
    return set(extract_domains(blocks[idx])) if idx is not None else set()


def folder_ref_parts(folder_ref: str) -> list[str]:
    ref = folder_ref.strip()
    if not ref:
        return []
    parts = [p for p in ref.strip("/").split("/") if p]
    if parts and parts[0] == "Local Folders":
        parts = parts[1:]
    if any(p in {".", ".."} for p in parts):
        return []
    return parts


def local_folder_mbox_path(profile: Path, folder_ref: str) -> Path | None:
    parts = folder_ref_parts(folder_ref)
    if not parts:
        return None
    mbox = profile / "Mail" / "Local Folders" / parts[0]
    for part in parts[1:]:
        mbox = mbox.with_name(mbox.name + ".sbd") / part
    return mbox


def find_local_folder_uri(profile: Path, folder_ref: str) -> str | None:
    mbox = local_folder_mbox_path(profile, folder_ref)
    return f"mailbox://{mbox}" if mbox and mbox.exists() else None


def make_route_filter_block(folder_ref: str, folder_uri: str, condition: str) -> str:
    name = f"{ROUTE_FILTER_PREFIX}{folder_ref}"
    return (
        f'name="{name}"\n'
        f'enabled="yes"\n'
        f'type="17"\n'
        f'action="Copy to folder"\n'
        f'actionValue="{folder_uri}"\n'
        f'condition="{condition}"\n'
    )


def get_all_route_domains(path: Path) -> dict[str, set[str]]:
    """Return {folder_ref: {domain, …}} from all [TBQ] Route -> * filters."""
    _, blocks = parse_blocks(path.read_text())
    result: dict[str, set[str]] = {}
    for b in blocks:
        name = block_name(b)
        if name.startswith(ROUTE_FILTER_PREFIX):
            folder = name[len(ROUTE_FILTER_PREFIX):]
            result.setdefault(folder, set()).update(extract_domains(b))
    return result


def get_all_route_domains_flat(path: Path) -> dict[str, str]:
    """Return {domain: folder_ref} from all route filters in one file."""
    flat: dict[str, str] = {}
    for folder, domains in get_all_route_domains(path).items():
        for d in domains:
            flat[d] = folder
    return flat


def write_route_filters(path: Path, routes: dict[str, set[str]], profile: Path) -> None:
    """Write (or remove) all [TBQ] Route -> * filters.

    routes: {folder_ref: {domain, …}} — complete desired state.
    """
    content = path.read_text()
    header, blocks = parse_blocks(content)

    # Preserve route filters whose target folder cannot currently be resolved.
    # This prevents a missing local folder from deleting previously working
    # route state while still allowing valid route changes to be rebuilt.
    kept_blocks: list[str] = []
    for b in blocks:
        name = block_name(b)
        if not name.startswith(ROUTE_FILTER_PREFIX):
            kept_blocks.append(b)
            continue
        folder_ref = name[len(ROUTE_FILTER_PREFIX):]
        if find_local_folder_uri(profile, folder_ref) is None:
            kept_blocks.append(b)
    blocks = kept_blocks

    # Build new route filter blocks in sorted folder order.
    new_route_blocks: list[str] = []
    for folder_ref in sorted(routes):
        domains = routes[folder_ref]
        if not domains:
            continue
        uri = find_local_folder_uri(profile, folder_ref)
        if uri is None:
            continue
        new_route_blocks.append(
            make_route_filter_block(folder_ref, uri, build_condition(sorted(domains)))
        )

    if new_route_blocks:
        anchor = next(
            (i for i, b in enumerate(blocks) if block_name(b) == ROUTE_INSERT_BEFORE),
            0,
        )
        for j, nb in enumerate(new_route_blocks):
            blocks.insert(anchor + j, nb)

    path.write_text(header + "".join(blocks))


def write_filter(path: Path, domains: set[str]) -> None:
    content = path.read_text()
    header, blocks = parse_blocks(content)
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)

    if not domains:
        if idx is not None:
            blocks = [b for b in blocks if block_name(b) != FILTER_NAME]
        path.write_text(header + "".join(blocks))
        return

    new_block = make_filter_block(build_condition(sorted(domains)))
    if idx is not None:
        blocks[idx] = new_block
    else:
        anchor = next((i for i, b in enumerate(blocks) if block_name(b) == INSERT_AFTER), None)
        if anchor is not None:
            blocks.insert(anchor + 1, new_block)
        else:
            fb = next((i for i, b in enumerate(blocks) if block_name(b) == FALLBACK_BEFORE), None)
            blocks.insert(fb if fb is not None else len(blocks), new_block)
    path.write_text(header + "".join(blocks))


def get_catchall_enabled(path: Path) -> bool | None:
    """Return True/False for the catch-all filter's enabled state, None if not found."""
    _, blocks = parse_blocks(path.read_text())
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == CATCHALL_FILTER_NAME), None)
    if idx is None:
        return None
    m = re.search(r'^enabled="(yes|no)"', blocks[idx], re.MULTILINE)
    return (m.group(1) == "yes") if m else None


def set_catchall_enabled(path: Path, enabled: bool) -> None:
    content = path.read_text()
    header, blocks = parse_blocks(content)
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == CATCHALL_FILTER_NAME), None)
    if idx is None:
        return
    val = "yes" if enabled else "no"
    blocks[idx] = re.sub(
        r'^enabled="(?:yes|no)"',
        f'enabled="{val}"',
        blocks[idx],
        flags=re.MULTILINE,
    )
    path.write_text(header + "".join(blocks))


def dn(n: int) -> str:
    return f"{n} domain{'s' if n != 1 else ''}"


def cmd_list() -> int:
    no_review = NO_REVIEW_MARKER.exists()
    role = "no-review" if no_review else "review"
    print(f"Role: {role} (marker {'set' if no_review else 'not set'}: {NO_REVIEW_MARKER})")
    print()

    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    print(f'Catch-all ("{CATCHALL_FILTER_NAME}"):')
    for path in filter_files:
        account = path.parent.name
        state = get_catchall_enabled(path)
        if state is None:
            print(f"  {account}: (filter not found)")
        else:
            print(f"  {account}: {'enabled' if state else 'disabled'}")

    print()
    print(f'Current "{FILTER_NAME}" filter:')
    for path in filter_files:
        account = path.parent.name
        domains = sorted(get_filter_domains(path))
        if domains:
            print(f"  {account} ({dn(len(domains))}):")
            for d in domains:
                print(f"    {d}")
        else:
            print(f"  {account}: (no filter)")

    print()
    print(f'Current "{ROUTE_FILTER_PREFIX}*" filters:')
    for path in filter_files:
        account = path.parent.name
        routes = get_all_route_domains(path)
        if routes:
            total = sum(len(v) for v in routes.values())
            print(f"  {account} ({dn(total)}):")
            for folder_name in sorted(routes):
                for d in sorted(routes[folder_name]):
                    print(f"    {d} -> {folder_name}")
        else:
            print(f"  {account}: (no routes)")
    return 0


def cmd_apply(dry_run: bool = False, no_review: bool | None = None) -> int:
    if no_review is None:
        no_review = NO_REVIEW_MARKER.exists()

    catchall_target = not no_review
    role = "no-review" if no_review else "review"

    print(f"Command file: {DOMAINS_FILE}")
    print(f"Role: {role}")
    print()

    block_queue, route_queue = read_queue()
    has_queue = bool(block_queue or route_queue)

    if has_queue:
        net_adds    = {d for d, a in block_queue.items() if a == "add"}
        net_deletes = {d for d, a in block_queue.items() if a == "delete"}
        net_routes   = {d: f for d, f in route_queue.items() if f is not None}
        net_unroutes = {d for d, f in route_queue.items() if f is None}
        n_add, n_del       = len(net_adds), len(net_deletes)
        n_route, n_unroute = len(net_routes), len(net_unroutes)
        print(f"  Pending: {n_add} block add{'s' if n_add != 1 else ''}, "
              f"{n_del} block delete{'s' if n_del != 1 else ''}, "
              f"{n_route} route{'s' if n_route != 1 else ''}, "
              f"{n_unroute} unroute{'s' if n_unroute != 1 else ''}")
        print()
    else:
        net_adds = net_deletes = net_unroutes = set()
        net_routes = {}

    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    # ── Catch-all plan ────────────────────────────────────────────────────
    catchall_updates: list[Path] = []
    for p in filter_files:
        state = get_catchall_enabled(p)
        if state is None:
            print(f"  Warning: catch-all filter not found in {p.parent.name}", file=sys.stderr)
        elif state != catchall_target:
            catchall_updates.append(p)

    if not has_queue and not catchall_updates:
        print("No pending changes.")
        return 0

    if not dry_run and is_tb_running():
        print("ERROR: Thunderbird is running — quit it before applying changes.", file=sys.stderr)
        return 1

    # ── Block domain plan ─────────────────────────────────────────────────
    all_current: set[str] = set()
    for path in filter_files:
        all_current |= get_filter_domains(path)

    to_add           = sorted(net_adds - all_current)
    to_delete        = sorted(net_deletes & all_current)
    no_change_domains = sorted(all_current - net_deletes)
    not_found_blocks = sorted(net_deletes - all_current)
    final_block_set  = (all_current | net_adds) - net_deletes

    if has_queue:
        print(f"Block — No change ({len(no_change_domains)}):")
        for d in no_change_domains:
            print(f"  {d}")
        if not no_change_domains:
            print("  (none)")

        print(f"Block — Add ({len(to_add)}):")
        for d in to_add:
            print(f"  + {d}")
        if not to_add:
            print("  (none)")

        total_del = len(to_delete) + len(not_found_blocks)
        print(f"Block — Delete ({total_del}):")
        for d in to_delete:
            print(f"  - {d}")
        for d in not_found_blocks:
            print(f"  ? {d}  (not in filter — no action)")
        if not to_delete and not not_found_blocks:
            print("  (none)")

    # ── Route plan ────────────────────────────────────────────────────────
    all_current_routes: dict[str, str] = {}
    for path in filter_files:
        all_current_routes.update(get_all_route_domains_flat(path))

    missing_route_targets = {
        d: f for d, f in net_routes.items()
        if find_local_folder_uri(profile, f) is None
    }
    valid_net_routes = {
        d: f for d, f in net_routes.items()
        if d not in missing_route_targets
    }

    routes_to_set    = {d: f for d, f in valid_net_routes.items()
                        if all_current_routes.get(d) != f}
    routes_to_delete = sorted(d for d in net_unroutes if d in all_current_routes)
    routes_not_found = sorted(d for d in net_unroutes if d not in all_current_routes)

    final_routes_flat: dict[str, str] = {**all_current_routes, **valid_net_routes}
    for d in net_unroutes:
        final_routes_flat.pop(d, None)
    final_routes: dict[str, set[str]] = {}
    for domain, folder in final_routes_flat.items():
        final_routes.setdefault(folder, set()).add(domain)

    if has_queue:
        print()
        print(f"Route — Add/Update ({len(routes_to_set)}):")
        for d, f in sorted(routes_to_set.items()):
            print(f"  + {d} -> {f}")
        if not routes_to_set:
            print("  (none)")

        if missing_route_targets:
            print(f"Route — Deferred ({len(missing_route_targets)}):")
            for d, f in sorted(missing_route_targets.items()):
                print(f"  ! {d} -> {f}  (local folder not found — queue entry kept)")

        total_unroute = len(routes_to_delete) + len(routes_not_found)
        print(f"Route — Remove ({total_unroute}):")
        for d in routes_to_delete:
            print(f"  - {d}  (was -> {all_current_routes[d]})")
        for d in routes_not_found:
            print(f"  ? {d}  (not routed — no action)")
        if not routes_to_delete and not routes_not_found:
            print("  (none)")

    # ── Catch-all plan output ─────────────────────────────────────────────
    if catchall_updates:
        action = "Enable" if catchall_target else "Disable"
        print()
        print(f"Catch-all — {action} ({len(catchall_updates)}):")
        for p in catchall_updates:
            print(f"  {p.parent.name}")

    any_change = bool(to_add or to_delete or routes_to_set or routes_to_delete
                      or catchall_updates)
    print()

    if not any_change:
        print("No filter changes needed." + (" (dry run)" if dry_run else ""))
        if not dry_run:
            if missing_route_targets:
                write_remaining_queue(missing_route_targets)
            else:
                clear_queue()
        return 0

    if dry_run:
        print("(dry run — no changes applied)")
        return 0

    try:
        answer = input("Apply these changes? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        return 1

    if answer not in ("y", "yes"):
        print("Aborted.")
        return 1

    catchall_update_set = set(catchall_updates)
    print()
    for path in filter_files:
        account = path.parent.name
        parts = []

        if to_add or to_delete:
            write_filter(path, final_block_set)
            if to_add:
                parts.append(f"+{len(to_add)} block")
            if to_delete:
                parts.append(f"-{len(to_delete)} block")

        if routes_to_set or routes_to_delete:
            write_route_filters(path, final_routes, profile)
            if routes_to_set:
                parts.append(f"+{len(routes_to_set)} route")
            if routes_to_delete:
                parts.append(f"-{len(routes_to_delete)} route")

        if path in catchall_update_set:
            set_catchall_enabled(path, catchall_target)
            parts.append("catch-all " + ("enabled" if catchall_target else "disabled"))

        if parts:
            totals = []
            if to_add or to_delete:
                totals.append(f"{dn(len(final_block_set))} blocks")
            if routes_to_set or routes_to_delete:
                totals.append(f"{dn(len(final_routes_flat))} routes")
            suffix = f", {', '.join(totals)} total" if totals else ""
            print(f"  {account}: updated ({', '.join(parts)}{suffix})")

    if has_queue:
        if missing_route_targets:
            write_remaining_queue(missing_route_targets)
        else:
            clear_queue()
    print()
    print("Done. Start Thunderbird to load the updated filters.")
    return 0


def main() -> int:
    args = sys.argv[1:]
    if not args:
        return cmd_apply()
    if args[0] in ("--list", "-l"):
        return cmd_list()
    if args[0] in ("--dry-run", "-n"):
        return cmd_apply(dry_run=True)
    if args[0] == "--no-review":
        return cmd_apply(no_review=True)
    if args[0] in ("--help", "-h"):
        print(__doc__.strip())
        return 0
    print(f"Unknown option: {args[0]}", file=sys.stderr)
    print(__doc__.strip())
    return 1


if __name__ == "__main__":
    sys.exit(main())
