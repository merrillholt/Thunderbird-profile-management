#!/usr/bin/env python3
"""Apply queued domain block changes to Thunderbird filter files.

Usage:
  tbblock-rebuild           preview changes, prompt, and apply
  tbblock-rebuild --list    list domains in the current [TBQ] Blocked domains filter
"""

from __future__ import annotations

import configparser
import re
import subprocess
import sys
from pathlib import Path

DOMAINS_FILE = Path(__file__).resolve().parent / "blocked_domains.txt"
FLATPAK_TB_DIR = Path.home() / ".var/app/org.mozilla.Thunderbird/.thunderbird"
FILTER_NAME = "[TBQ] Blocked domains -> Trash"
INSERT_AFTER = "[TBQ] Trash senders -> Trash"
FALLBACK_BEFORE = "[TBQ] Spoofed trusted domains -> Spoofed"


def find_profile() -> Path:
    ini = FLATPAK_TB_DIR / "profiles.ini"
    if ini.exists():
        cp = configparser.ConfigParser()
        cp.read(ini)

        def resolve(rel: str, is_relative: bool) -> Path:
            return FLATPAK_TB_DIR / rel if is_relative else Path(rel)

        # [Install*] sections reflect the per-install active profile; check these first.
        for section in cp.sections():
            if section.startswith("Install"):
                rel = cp.get(section, "default", fallback="")
                if rel:
                    return resolve(rel, is_relative=True)

        # Fall back to the profile with Default=1.
        for section in cp.sections():
            if cp.get(section, "default", fallback="") == "1":
                rel = cp.get(section, "path", fallback="")
                if rel:
                    is_relative = cp.get(section, "isrelative", fallback="1") == "1"
                    return resolve(rel, is_relative)

    candidates = sorted(FLATPAK_TB_DIR.glob("*.default*"))
    if candidates:
        return candidates[0]
    raise RuntimeError(f"No Thunderbird profile found in {FLATPAK_TB_DIR}")


def is_tb_running() -> bool:
    for pattern in ("org.mozilla.Thunderbird", "thunderbird-bin", "thunderbird"):
        try:
            r = subprocess.run(["pgrep", "-f", pattern], capture_output=True)
            if r.returncode == 0:
                return True
        except FileNotFoundError:
            pass
    return False


def normalize(d: str) -> str:
    return "@" + d.strip().lstrip("@").lower()


def read_queue() -> dict[str, str]:
    """Parse blocked_domains.txt → {domain: last_action}. Empty dict if no pending entries."""
    if not DOMAINS_FILE.exists():
        return {}
    net: dict[str, str] = {}
    for line in DOMAINS_FILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        parts = line.split(None, 1)
        if len(parts) != 2 or parts[0] not in ("add", "delete"):
            continue
        net[normalize(parts[1])] = parts[0]
    return net


def clear_queue() -> None:
    DOMAINS_FILE.write_text(
        "# Pending domain block changes. Managed by tbblock.\n"
        "# Run tbblock-rebuild to apply. File is cleared after apply.\n"
    )


def parse_blocks(content: str) -> tuple[str, list[str]]:
    lines = content.splitlines(keepends=True)
    header_lines: list[str] = []
    body_start = len(lines)
    for i, line in enumerate(lines):
        if line.startswith("name="):
            body_start = i
            break
        header_lines.append(line)
    header = "".join(header_lines)
    body = "".join(lines[body_start:])
    raw = re.split(r"(?=^name=)", body, flags=re.MULTILINE)
    return header, [b for b in raw if b.strip()]


def block_name(block: str) -> str:
    m = re.match(r'^name="([^"]*)"', block)
    return m.group(1) if m else ""


def extract_domains(block: str) -> list[str]:
    m = re.search(r'^condition="(.+)"', block, re.MULTILINE)
    if not m:
        return []
    return sorted(re.findall(r'\(from,contains,([^)]+)\)', m.group(1)))


def build_condition(domains: list[str]) -> str:
    return "OR " + " OR ".join(f"(from,contains,{d})" for d in domains)


def make_filter_block(condition: str) -> str:
    return (
        f'name="{FILTER_NAME}"\n'
        f'enabled="yes"\n'
        f'type="17"\n'
        f'action="AddTag"\n'
        f'actionValue="trash"\n'
        f'action="AddTag"\n'
        f'actionValue="tbq_identified"\n'
        f'action="Stop execution"\n'
        f'condition="{condition}"\n'
    )


def get_filter_domains(path: Path) -> set[str]:
    _, blocks = parse_blocks(path.read_text())
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)
    return set(extract_domains(blocks[idx])) if idx is not None else set()


def write_filter(path: Path, domains: set[str]) -> None:
    content = path.read_text()
    header, blocks = parse_blocks(content)
    idx = next((i for i, b in enumerate(blocks) if block_name(b) == FILTER_NAME), None)

    if not domains:
        if idx is not None:
            blocks = [b for b in blocks if block_name(b) != FILTER_NAME]
        path.write_text(header + "".join(blocks))
        return

    new_block = make_filter_block(build_condition(sorted(domains)))
    if idx is not None:
        blocks[idx] = new_block
    else:
        anchor = next((i for i, b in enumerate(blocks) if block_name(b) == INSERT_AFTER), None)
        if anchor is not None:
            blocks.insert(anchor + 1, new_block)
        else:
            fb = next((i for i, b in enumerate(blocks) if block_name(b) == FALLBACK_BEFORE), None)
            blocks.insert(fb if fb is not None else len(blocks), new_block)
    path.write_text(header + "".join(blocks))


def dn(n: int) -> str:
    return f"{n} domain{'s' if n != 1 else ''}"


def cmd_list() -> int:
    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    print(f'Current "{FILTER_NAME}" filter:')
    for path in filter_files:
        account = path.parent.name
        domains = sorted(get_filter_domains(path))
        if domains:
            print(f"  {account} ({dn(len(domains))}):")
            for d in domains:
                print(f"    {d}")
        else:
            print(f"  {account}: (no filter)")
    return 0


def cmd_apply() -> int:
    print(f"Command file: {DOMAINS_FILE}")

    queue = read_queue()
    if not queue:
        print("  (empty — no pending changes)")
        return 0

    net_adds = {d for d, a in queue.items() if a == "add"}
    net_deletes = {d for d, a in queue.items() if a == "delete"}
    n_add, n_del = len(net_adds), len(net_deletes)
    print(f"  Pending: {n_add} add{'s' if n_add != 1 else ''}, "
          f"{n_del} delete{'s' if n_del != 1 else ''}")
    print()

    if is_tb_running():
        print("ERROR: Thunderbird is running — quit it before applying changes.", file=sys.stderr)
        return 1

    try:
        profile = find_profile()
    except RuntimeError as e:
        print(f"ERROR: {e}", file=sys.stderr)
        return 1

    filter_files = sorted((profile / "ImapMail").glob("*/msgFilterRules.dat"))
    if not filter_files:
        print("No IMAP filter files found.", file=sys.stderr)
        return 1

    # Build unified domain view across all accounts
    all_current: set[str] = set()
    for path in filter_files:
        all_current |= get_filter_domains(path)

    to_add = sorted(net_adds - all_current)
    to_delete = sorted(net_deletes & all_current)
    no_change = sorted(all_current - net_deletes)
    not_found = sorted(net_deletes - all_current)
    final_set = (all_current | net_adds) - net_deletes

    # Display plan
    print(f"No change ({len(no_change)}):")
    if no_change:
        for d in no_change:
            print(f"  {d}")
    else:
        print("  (none)")

    print(f"Add ({len(to_add)}):")
    if to_add:
        for d in to_add:
            print(f"  + {d}")
    else:
        print("  (none)")

    total_del = len(to_delete) + len(not_found)
    print(f"Delete ({total_del}):")
    if to_delete:
        for d in to_delete:
            print(f"  - {d}")
    if not_found:
        for d in not_found:
            print(f"  ? {d}  (not in filter — no action)")
    if not to_delete and not not_found:
        print("  (none)")

    any_change = bool(to_add or to_delete)
    print()

    if not any_change:
        print("No filter changes needed.")
        clear_queue()
        return 0

    try:
        answer = input("Apply these changes? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        return 1

    if answer not in ("y", "yes"):
        print("Aborted.")
        return 1

    print()
    for path in filter_files:
        write_filter(path, final_set)
        account = path.parent.name
        parts = []
        if to_add:
            parts.append(f"+{len(to_add)}")
        if to_delete:
            parts.append(f"-{len(to_delete)}")
        print(f"  {account}: updated ({', '.join(parts)}, {dn(len(final_set))} total)")

    clear_queue()
    print()
    print("Done. Start Thunderbird to load the updated filters.")
    return 0


def main() -> int:
    args = sys.argv[1:]
    if not args:
        return cmd_apply()
    if args[0] in ("--list", "-l"):
        return cmd_list()
    if args[0] in ("--help", "-h"):
        print(__doc__.strip())
        return 0
    print(f"Unknown option: {args[0]}", file=sys.stderr)
    print(__doc__.strip())
    return 1


if __name__ == "__main__":
    sys.exit(main())
