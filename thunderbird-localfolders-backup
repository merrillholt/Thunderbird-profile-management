#!/usr/bin/env bash
# Historical snapshot backup of Thunderbird Local Folders using restic.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
pcloud_mount="/mnt/pcloud"
pcloud_drive="${HOME}/pCloudDrive"
backup_root_rel="Thunderbird Backup"
default_repo_subdir="localfolders-restic"
activity_fallback="${HOME}/.local/share/thunderbird-backup/activity.log.fallback"

keep_daily=7
keep_weekly=4
keep_monthly=12

dry_run=false
subcmd="backup"
repo_arg=""

log_activity() {
    local action="$1" status="$2" detail="$3" log_path="$4"
    local line
    line=$(printf '%s\t%s\t%s\t%s\t%s' "$(date '+%Y-%m-%d %H:%M:%S')" "$(hostname -s)" "${action}" "${status}" "${detail}")
    if [[ -n "${log_path}" ]] && printf '%s\n' "${line}" >> "${log_path}" 2>/dev/null; then
        return 0
    fi
    mkdir -p "$(dirname "${activity_fallback}")"
    printf '%s\n' "${line}" >> "${activity_fallback}"
    echo "Warning: could not write activity log to ${log_path:-(unset)}; appended to ${activity_fallback}" >&2
    return 0
}

usage() {
    cat <<EOF
Usage: $(basename "$0") [--dry-run] [--repo PATH] [SUBCOMMAND]

Subcommands (default: backup):
  backup     Create a new restic snapshot of Local Folders
  init       Initialize the restic repository
  snapshots  List existing snapshots
  prune      Apply retention policy and remove old data

Options:
  --repo PATH  Restic repository path (overrides RESTIC_REPOSITORY and pCloud default)
  --dry-run    Show what would happen without writing
  -h, --help   Show this help

Retention policy: keep last ${keep_daily} daily, ${keep_weekly} weekly, ${keep_monthly} monthly snapshots.

Default repository: pCloud/${backup_root_rel}/${default_repo_subdir}
Password: RESTIC_PASSWORD or RESTIC_PASSWORD_FILE env vars; or place password in
  pCloud/${backup_root_rel}/.restic-password (chmod 600).
EOF
}

# Parse args
i=0
args=("$@")
while (( i < ${#args[@]} )); do
    case "${args[$i]}" in
        --dry-run) dry_run=true ;;
        --repo)
            (( i++ )) || true
            repo_arg="${args[$i]}"
            ;;
        --repo=*) repo_arg="${args[$i]#--repo=}" ;;
        -h|--help) usage; exit 0 ;;
        backup|init|snapshots|prune) subcmd="${args[$i]}" ;;
        *)
            echo "Error: Unknown option: ${args[$i]}" >&2
            usage >&2
            exit 1
            ;;
    esac
    (( i++ )) || true
done

# Resolve pCloud location
if [[ -d "${pcloud_mount}" ]]; then
    backup_root="${pcloud_mount}/${backup_root_rel}"
elif [[ -d "${pcloud_drive}" ]]; then
    backup_root="${pcloud_drive}/${backup_root_rel}"
else
    backup_root=""
fi
activity_log="${backup_root}/activity.log"

if ! command -v restic &>/dev/null; then
    echo "Error: restic not found. Install it with: sudo apt install restic" >&2
    echo "  or see https://restic.net" >&2
    if [[ "${subcmd}" == "backup" && "${dry_run}" != true && -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "restic-not-installed" "${activity_log}"
    fi
    exit 1
fi

# Set repository
if [[ -n "${repo_arg}" ]]; then
    export RESTIC_REPOSITORY="${repo_arg}"
elif [[ -z "${RESTIC_REPOSITORY:-}" ]]; then
    if [[ -z "${backup_root}" ]]; then
        echo "Error: No pCloud mount found and RESTIC_REPOSITORY not set." >&2
        exit 1
    fi
    export RESTIC_REPOSITORY="${backup_root}/${default_repo_subdir}"
fi

# Use default password file if no password is configured
if [[ -z "${RESTIC_PASSWORD:-}" && -z "${RESTIC_PASSWORD_FILE:-}" && -n "${backup_root}" ]]; then
    default_pw="${backup_root}/.restic-password"
    if [[ -f "${default_pw}" ]]; then
        export RESTIC_PASSWORD_FILE="${default_pw}"
    fi
fi

echo "Repository: ${RESTIC_REPOSITORY}"

# ── subcommands that don't need profile detection ────────────────────────────

if [[ "${subcmd}" == "init" ]]; then
    if "${dry_run}"; then
        echo "(dry-run: would run: restic init)"
    else
        mkdir -p "${RESTIC_REPOSITORY}"
        restic init
        echo
        echo "Repository initialized."
        if [[ -n "${backup_root}" ]]; then
            pw_hint="${backup_root}/.restic-password"
            echo "Tip: Save your password to ${pw_hint} (chmod 600) for automatic use."
        fi
    fi
    exit 0
fi

if [[ "${subcmd}" == "snapshots" ]]; then
    restic snapshots --tag local-folders
    exit 0
fi

if [[ "${subcmd}" == "prune" ]]; then
    prune_args=(
        forget --prune
        --keep-daily "${keep_daily}"
        --keep-weekly "${keep_weekly}"
        --keep-monthly "${keep_monthly}"
        --tag local-folders
    )
    "${dry_run}" && prune_args+=(--dry-run)
    restic "${prune_args[@]}"
    exit 0
fi

# ── backup subcommand: requires profile detection ────────────────────────────

run_quick_check() {
    if command -v timeout >/dev/null 2>&1; then
        timeout 5s "$@" >/dev/null 2>&1
    else
        "$@" >/dev/null 2>&1
    fi
}

find_flatpak_thunderbird() {
    local app_id
    for app_id in org.mozilla.thunderbird_esr org.mozilla.thunderbird org.mozilla.Thunderbird; do
        if command -v flatpak &>/dev/null && run_quick_check flatpak info "${app_id}"; then
            printf '%s\n' "${app_id}"
            return 0
        fi
    done
    return 1
}

check_thunderbird_running() {
    pgrep -x thunderbird &>/dev/null || \
    pgrep -x thunderbird-bin &>/dev/null || \
    { command -v flatpak &>/dev/null && flatpak ps --columns=application 2>/dev/null | grep -Eq '^(org\.mozilla\.thunderbird_esr|org\.mozilla\.thunderbird|org\.mozilla\.Thunderbird)$'; }
}

if TB_FLATPAK_APP_ID=$(find_flatpak_thunderbird); then
    tb_dir="${HOME}/.var/app/${TB_FLATPAK_APP_ID}/.thunderbird"
elif command -v snap &>/dev/null && run_quick_check snap list thunderbird; then
    tb_dir="${HOME}/snap/thunderbird/common/.thunderbird"
elif command -v thunderbird &>/dev/null; then
    tb_dir="${HOME}/.thunderbird"
else
    echo "Error: No Thunderbird installation found." >&2
    if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "thunderbird-not-found" "${activity_log}"
    fi
    exit 1
fi

profiles_ini="${tb_dir}/profiles.ini"
if [[ ! -f "${profiles_ini}" ]]; then
    echo "Error: ${profiles_ini} not found." >&2
    if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "profiles-ini-missing" "${activity_log}"
    fi
    exit 1
fi

# Determine active profile path.
profile_path=$(python3 "${SCRIPT_DIR}/thunderbird_profile.py" "${tb_dir}") || {
    echo "Error: Could not determine active Thunderbird profile from ${tb_dir}/profiles.ini" >&2
    if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "profile-detect-failed" "${activity_log}"
    fi
    exit 1
}

local_folders="${profile_path}/Mail/Local Folders"
if [[ ! -d "${local_folders}" ]]; then
    echo "Error: Local Folders directory not found: ${local_folders}" >&2
    if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "local-folders-missing" "${activity_log}"
    fi
    exit 1
fi

if ! "${dry_run}" && check_thunderbird_running; then
    echo "Error: Thunderbird is running. Close it before backing up Local Folders." >&2
    if [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "thunderbird-running" "${activity_log}"
    fi
    exit 1
fi

echo "Local Folders: ${local_folders}"
echo

backup_args=(
    backup
    --tag thunderbird
    --tag local-folders
    --host "$(hostname -s)"
    "${local_folders}"
)
"${dry_run}" && backup_args+=(--dry-run)

set +e
restic "${backup_args[@]}"
restic_status=$?
set -e

if [[ "${restic_status}" -ne 0 ]]; then
    if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
        log_activity "localfolders-backup" "error" "restic-exit-${restic_status}" "${activity_log}"
    fi
    exit "${restic_status}"
fi

if ! "${dry_run}" && [[ -n "${backup_root}" ]]; then
    log_activity "localfolders-backup" "ok" "" "${activity_log}"
fi
