#!/usr/bin/env bash
# Manage the Thunderbird domain block queue.
#
# Usage:
#   tbblock --add @domain.com [...]     queue domains to add
#   tbblock --delete @domain.com [...]  queue domains to delete
#   tbblock --list                      show pending changes
#   tbblock --help                      show this help
#
# Run tbblock-rebuild to apply queued changes (Thunderbird must be closed).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
DOMAINS_FILE="$SCRIPT_DIR/blocked_domains.txt"

usage() {
  cat <<'EOF'
Usage:
  tbblock --add @domain.com [...]           queue domains to block
  tbblock --delete @domain.com [...]        queue domains to unblock
  tbblock --route @domain.com FolderName    queue domain-to-folder routing
  tbblock --unroute @domain.com             queue removal of domain routing
  tbblock --list                            show pending changes
  tbblock --help                            show this help

Run tbblock-rebuild to apply queued changes (Thunderbird must be closed).
EOF
}

normalize() {
  local d="${1#@}"
  printf '@%s\n' "${d,,}"
}

init_file() {
  [[ -f "$DOMAINS_FILE" ]] && return
  cat > "$DOMAINS_FILE" <<'EOF'
# Pending domain block changes. Managed by tbblock.
# Run tbblock-rebuild to apply. File is cleared after apply.
EOF
}

case "${1:-}" in
  --help|-h)
    usage
    exit 0
    ;;

  --list|-l)
    echo "Command file: $DOMAINS_FILE"
    if [[ -f "$DOMAINS_FILE" ]]; then
      pending="$(grep -Ev '^\s*(#|$)' "$DOMAINS_FILE" 2>/dev/null | sort || true)"
      if [[ -n "$pending" ]]; then
        echo "$pending"
      else
        echo "  (no pending changes)"
      fi
    else
      echo "  (file not found)"
    fi
    ;;

  --add)
    shift
    [[ $# -eq 0 ]] && { echo "Error: --add requires at least one domain" >&2; exit 1; }
    init_file
    for arg in "$@"; do
      d="$(normalize "$arg")"
      echo "add $d" >> "$DOMAINS_FILE"
      echo "Queued: add $d"
    done
    ;;

  --delete|-d)
    shift
    [[ $# -eq 0 ]] && { echo "Error: --delete requires at least one domain" >&2; exit 1; }
    init_file
    for arg in "$@"; do
      d="$(normalize "$arg")"
      echo "delete $d" >> "$DOMAINS_FILE"
      echo "Queued: delete $d"
    done
    ;;

  --route)
    shift
    [[ $# -lt 2 ]] && { echo "Error: --route requires a domain and folder name" >&2; exit 1; }
    d="$(normalize "$1")"
    folder="$2"
    init_file
    echo "route $d $folder" >> "$DOMAINS_FILE"
    echo "Queued: route $d -> $folder"
    ;;

  --unroute)
    shift
    [[ $# -eq 0 ]] && { echo "Error: --unroute requires at least one domain" >&2; exit 1; }
    init_file
    for arg in "$@"; do
      d="$(normalize "$arg")"
      echo "unroute $d" >> "$DOMAINS_FILE"
      echo "Queued: unroute $d"
    done
    ;;

  "")
    usage >&2
    exit 1
    ;;

  *)
    echo "Unknown option: $1" >&2
    usage >&2
    exit 1
    ;;
esac
