#!/usr/bin/env bash
# Manage the Thunderbird domain block list.
#
# Usage:
#   tbblock @domain.com            # add a domain
#   tbblock --delete @domain.com   # remove a domain
#   tbblock --list                 # list all blocked domains
#   tbblock --rebuild              # rebuild Thunderbird filters (TB must be closed)
#   tbblock --help                 # show this help
#
# Add/delete can be run while Thunderbird is open. Run --rebuild (or
# tbblock-rebuild directly) after closing Thunderbird to apply changes.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOMAINS_FILE="$SCRIPT_DIR/blocked_domains.txt"
REBUILD="$SCRIPT_DIR/tbblock-rebuild"

usage() {
  cat >&2 <<EOF
Usage: tbblock @domain.com            add a domain to the block list
       tbblock --delete @domain.com   remove a domain from the block list
       tbblock --list                 list all blocked domains
       tbblock --rebuild              rebuild Thunderbird filters (TB must be closed)
       tbblock --help                 show this help
EOF
  exit 1
}

normalize_domain() {
  local d="${1#@}"
  echo "@${d,,}"
}

case "${1:-}" in
  --help|-h)
    usage
    ;;

  --list|-l)
    if [[ -f "$DOMAINS_FILE" ]]; then
      grep -v '^\s*#' "$DOMAINS_FILE" | grep -v '^\s*$' | sort
    fi
    exit 0
    ;;

  --delete|-d)
    [[ -z "${2:-}" ]] && usage
    domain="$(normalize_domain "$2")"
    if [[ ! -f "$DOMAINS_FILE" ]] || ! grep -qxF "$domain" "$DOMAINS_FILE" 2>/dev/null; then
      echo "Not in block list: $domain"
      exit 0
    fi
    tmp="$(mktemp)"
    grep -vxF "$domain" "$DOMAINS_FILE" > "$tmp"
    mv "$tmp" "$DOMAINS_FILE"
    echo "Deleted: $domain"
    ;;

  --rebuild|-r)
    if [[ ! -x "$REBUILD" ]]; then
      echo "Error: tbblock-rebuild not found at $REBUILD" >&2
      exit 1
    fi
    "$REBUILD"
    ;;

  "")
    usage
    ;;

  -*)
    echo "Unknown option: $1" >&2
    usage
    ;;

  *)
    domain="$(normalize_domain "$1")"
    touch "$DOMAINS_FILE"
    if grep -qxF "$domain" "$DOMAINS_FILE" 2>/dev/null; then
      echo "Already blocked: $domain"
    else
      echo "$domain" >> "$DOMAINS_FILE"
      echo "Added: $domain"
    fi
    ;;
esac
