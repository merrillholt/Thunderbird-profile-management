#!/usr/bin/env python3
"""Message-level mbox merge for Thunderbird local folders.

Saves messages unique to the destination (not in backup) before a restore
overwrites the profile, then re-merges them afterwards so no accumulated
messages are lost.

Usage:
  thunderbird-mbox-merge snapshot <src_local_dir> <dest_local_dir> <work_dir>
      Collect messages in dest not present in src; write to work_dir.

  thunderbird-mbox-merge merge <dest_local_dir> <work_dir>
      Append saved messages into the restored dest mboxes.
      Removes .msf index files for modified folders so Thunderbird
      rebuilds them on next open.
"""

from __future__ import annotations

import hashlib
import mailbox
import sys
from pathlib import Path


def message_key(msg) -> str:
    mid = msg.get("Message-ID", "").strip()
    if mid:
        return mid
    return "sha256:" + hashlib.sha256(msg.as_bytes()).hexdigest()


def mbox_files(directory: Path) -> list[Path]:
    """Return regular mbox files under a Local Folders tree."""
    if not directory.is_dir():
        return []
    return sorted(
        p
        for p in directory.rglob("*")
        if p.is_file() and p.suffix != ".msf"
    )


def display_path(path: Path, root: Path) -> str:
    try:
        return str(path.relative_to(root))
    except ValueError:
        return path.name


def msf_path(mbox_path: Path) -> Path:
    return mbox_path.parent / (mbox_path.name + ".msf")


def try_read_keys(path: Path) -> tuple[set[str], bool]:
    keys: set[str] = set()
    try:
        mb = mailbox.mbox(str(path), create=False)
        for msg in mb:
            keys.add(message_key(msg))
        mb.close()
    except Exception as e:
        print(f"  Warning: could not read {path}: {e}", file=sys.stderr)
        return keys, False
    return keys, True


def cmd_snapshot(src_dir: Path, dest_dir: Path, work_dir: Path) -> int:
    """Save dest messages not present in src to work_dir."""
    work_dir.mkdir(parents=True, exist_ok=True)
    total = 0
    folders = 0
    had_error = False
    for dest_mbox in mbox_files(dest_dir):
        rel_path = dest_mbox.relative_to(dest_dir)
        src_mbox = src_dir / rel_path
        if src_mbox.exists():
            src_keys, ok = try_read_keys(src_mbox)
            if not ok:
                had_error = True
                continue
        else:
            src_keys = set()
        unique: list[mailbox.mboxMessage] = []
        try:
            mb = mailbox.mbox(str(dest_mbox), create=False)
            for msg in mb:
                if message_key(msg) not in src_keys:
                    unique.append(msg)
            mb.close()
        except Exception as e:
            print(f"  Warning: could not read {display_path(dest_mbox, dest_dir)}: {e}", file=sys.stderr)
            had_error = True
            continue
        if unique:
            saved_mbox = work_dir / rel_path
            saved_mbox.parent.mkdir(parents=True, exist_ok=True)
            try:
                out = mailbox.mbox(str(saved_mbox), create=True)
                for msg in unique:
                    out.add(msg)
                out.flush()
                out.close()
            except Exception as e:
                print(f"  Warning: could not write preserved {rel_path}: {e}", file=sys.stderr)
                had_error = True
                continue
            total += len(unique)
            folders += 1
            print(f"  {rel_path}: {len(unique)} message(s) to preserve")
    if total:
        print(f"  Total: {total} message(s) across {folders} folder(s)")
    else:
        print("  (nothing to preserve)")
    return 1 if had_error else 0


def cmd_merge(dest_dir: Path, work_dir: Path) -> int:
    """Append saved messages into the restored dest mboxes."""
    saved = mbox_files(work_dir)
    if not saved:
        print("  (no messages to merge)")
        return 0
    total = 0
    had_error = False
    for saved_mbox in saved:
        rel_path = saved_mbox.relative_to(work_dir)
        dest_mbox = dest_dir / rel_path
        if dest_mbox.exists():
            existing, ok = try_read_keys(dest_mbox)
            if not ok:
                had_error = True
                continue
        else:
            existing = set()
        to_add: list[mailbox.mboxMessage] = []
        try:
            mb = mailbox.mbox(str(saved_mbox), create=False)
            for msg in mb:
                if message_key(msg) not in existing:
                    to_add.append(msg)
            mb.close()
        except Exception as e:
            print(f"  Warning: could not read saved {rel_path}: {e}", file=sys.stderr)
            had_error = True
            continue
        if not to_add:
            continue
        try:
            dest_mbox.parent.mkdir(parents=True, exist_ok=True)
            dst = mailbox.mbox(str(dest_mbox), create=True)
            for msg in to_add:
                dst.add(msg)
            dst.flush()
            dst.close()
        except Exception as e:
            print(f"  Warning: could not write {rel_path}: {e}", file=sys.stderr)
            had_error = True
            continue
        msf = msf_path(dest_mbox)
        if msf.exists():
            msf.unlink()
        total += len(to_add)
        print(f"  {rel_path}: merged {len(to_add)} message(s)")
    if total:
        print(f"  Total merged: {total} message(s)")
    else:
        print("  (nothing new to merge)")
    return 1 if had_error else 0


def main() -> int:
    args = sys.argv[1:]
    if len(args) == 4 and args[0] == "snapshot":
        return cmd_snapshot(Path(args[1]), Path(args[2]), Path(args[3]))
    if len(args) == 3 and args[0] == "merge":
        return cmd_merge(Path(args[1]), Path(args[2]))
    print(__doc__.strip(), file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
